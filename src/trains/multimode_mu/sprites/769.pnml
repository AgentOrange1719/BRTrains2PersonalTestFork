// Shared reverse-role resolver for mixed 769/769-9 formations.
switch(FEAT_TRAINS, SELF, switch_br_769_rev_from_mirror, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xC6]]) {
	457: switch_br_769_rev_role_by_pos;
	2457: switch_br_769_rev_role_by_pos;
	458: switch_br_769_9_rev_role_by_pos;
	2458: switch_br_769_9_rev_role_by_pos;
	switch_br_769_rev_role_by_pos;
}

