// ============================================================================
// Item Definitions
// ============================================================================
// Each item uses:
//   - articulated_part switch from the articulation block
//   - default sprite chain from sprites/350.pnml
//   - capacity/effect switches from this file

// Class 350/1
item(FEAT_TRAINS, item_BR350_1, 774) {
	property {
		variant_group: header_Desiro;
		name: string(STR_NAME_BR350_1);
		climates_available: ALL_CLIMATES;
		introduction_date: date(2004, 4, 21);
		model_life: 15;
		retire_early: 1;
		vehicle_life: 50;
		reliability_decay: 7;
		refittable_cargo_classes: CC_PASSENGERS;
		cargo_allow_refit: [PASS, TOUR];
		loading_speed: 25;
		cost_factor: 42;
		running_cost_factor: 38;
		sprite_id: SPRITE_ID_NEW_TRAIN;
		speed: 110 mph;
		refit_cost: 0;
		track_type: [THIRD, ELRL];
		ai_special_flag: AI_FLAG_CARGO;
		power: 2682 hp;
		running_cost_base: RUNNING_COST_ELECTRIC;
		misc_flags: TRAIN_FLAG_MU;
		dual_headed: 0;
		default_cargo_type: PASS;
		cargo_capacity: 50;
		weight: 190 ton;
		engine_class: ENGINE_CLASS_ELECTRIC;
		tractive_effort_coefficient: 0.3;
		air_drag_coefficient: 0.2;
		length: 8;
		effect_spawn_model_and_powered: EFFECT_SPAWN_MODEL_ELECTRIC;
		extra_weight_per_wagon: 0;
		bitmask_vehicle_info: 0;
		cargo_age_period: 185;
	}
	graphics {
		additional_text: sw_BR350_1_additional_text;
		can_attach_wagon: sw_BR350_can_attach_wagon;
		cargo_subtype_text: sw_BR350_1_cargo_subtype_text;
		articulated_part: sw_articulated_BR350_1;
		default: sw_BR350_1_direction;
		purchase: spriteset_BR350_Purchase;
		colour_mapping: return PALETTE_CC_FIRST;
		create_effect: sw_BR350_1_create_effect_by_pos;
		sound_effect: sw_sound_electric_350;
		cargo_capacity: sw_BR350_1_capacity;
		cost_factor: return(GetAdjustedCost(42));
		running_cost_factor: return(GetAdjustedCost(38));
	}
}

