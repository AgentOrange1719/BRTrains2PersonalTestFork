// ============================================================================
// Class 350 unit definitions (4-car articulated sets)
// ============================================================================
//
// This file defines gameplay behavior and item properties for:
//   - Class 350/1  (item 774)
//   - Class 350/2  (item 775)
//   - Class 350/3+4 (item 776)
//
// Sprite/livery/reversing role selection lives in:
//   src/trains/electric_mu/sprites/350.pnml
//
// High-level runtime behavior in this file:
//   1) Build each 4-car unit as a single item ID via articulated callbacks.
//   2) Apply seated capacity distribution by subclass.
//   3) Apply visual/effect callbacks for overhead and third-rail sparks.
// ============================================================================

// ============================================================================
// Articulation + Coupling Rules
// ============================================================================
// Build fixed 4-car units by returning the same item ID for articulated cars 1..3.
switch(FEAT_TRAINS, SELF, sw_articulated_BR350_1, extra_callback_info1) {
	1..3: return item_BR350_1;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, sw_articulated_BR350_2, extra_callback_info1) {
	1..3: return item_BR350_2;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, sw_articulated_BR350_34, extra_callback_info1) {
	1..3: return item_BR350_34;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, sw_BR350_can_attach_wagon, vehicle_type_id) {
	item_BR350_1:         return CB_RESULT_ATTACH_ALLOW;
	item_BR350_2:         return CB_RESULT_ATTACH_ALLOW;
	item_BR350_34:        return CB_RESULT_ATTACH_ALLOW;
	return string(STR_CANNOT_ATTACH);
}

// ============================================================================
// Capacity Chains (Seated only)
// ============================================================================
// Numbers are sourced from 2021 National Rail contract with West Midlands Trains, page 76


// Class 350/1 capacity splits.
switch(FEAT_TRAINS, SELF, sw_BR350_1_capacity, position_in_articulated_veh % 4) {
	0: return(57 * param_pax);
	1: return(58 * param_pax);
	2: return(57 * param_pax);
	3: return(58 * param_pax);
}

// Class 350/2 capacity splits.
switch(FEAT_TRAINS, SELF, sw_BR350_2_capacity, position_in_articulated_veh % 4) {
	0: return(68 * param_pax);
	1: return(67 * param_pax);
	2: return(68 * param_pax);
	3: return(67 * param_pax);
}

// Class 350/3+4 capacity splits.
switch(FEAT_TRAINS, SELF, sw_BR350_34_capacity, position_in_articulated_veh % 4) {
	0: return(60 * param_pax);
	1: return(59 * param_pax);
	2: return(60 * param_pax);
	3: return(59 * param_pax);
}

// ============================================================================
// Sound + Visual Effects
// ============================================================================
// create_effect chain:
// Detailed per-car spark placement. If both THIRD and ELRL are present, ELRL wins.
//
// Class 350/1:
//   - Overhead sparks: car index 2 forward, 1 reversed (panto car)
//   - Third-rail sparks: car indexes 0 and 3 (cab cars)
switch(FEAT_TRAINS, PARENT, sw_BR350_1_visual_effect_by_railtype_third, tile_powers_railtype("THIRD")) {
	1: visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 2, DISABLE_WAGON_POWER);
	visual_effect_and_powered(VISUAL_EFFECT_DISABLE, 0, DISABLE_WAGON_POWER);
}

switch(FEAT_TRAINS, PARENT, sw_BR350_1_visual_effect_by_railtype, tile_powers_railtype("ELRL")) {
	1: visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 2, DISABLE_WAGON_POWER);
	sw_BR350_1_visual_effect_by_railtype_third;
}

// Overhead position mapping for all 350 subclasses. Panto is on 3rd car when moving forward, 2nd when reversed
switch(FEAT_TRAINS, SELF, sw_BR350_1_create_effect_elrl_pos_fwd, position_in_articulated_veh % 4) {
	2: electric_create_visual_effect;
	return 0;
}
switch(FEAT_TRAINS, SELF, sw_BR350_1_create_effect_elrl_pos_rev, position_in_articulated_veh % 4) {
	1: electric_create_visual_effect;
	return 0;
}
switch(FEAT_TRAINS, PARENT, sw_BR350_1_create_effect_elrl_pos, vehicle_is_reversed) {
	1: sw_BR350_1_create_effect_elrl_pos_rev;
	sw_BR350_1_create_effect_elrl_pos_fwd;
}

// Class 350/1 third-rail pickups are on both cab cars.
switch(FEAT_TRAINS, SELF, sw_BR350_1_create_effect_third_pos, position_in_articulated_veh % 4) {
	0: electric_create_visual_effect_SAA3;
	3: electric_create_visual_effect_SAA3;
	return 0;
}
switch(FEAT_TRAINS, PARENT, sw_BR350_1_create_effect_by_railtype_third, tile_powers_railtype("THIRD")) {
	1: sw_BR350_1_create_effect_third_pos;
	return 0;
}

switch(FEAT_TRAINS, PARENT, sw_BR350_1_create_effect_by_railtype, tile_powers_railtype("ELRL")) {
	1: sw_BR350_1_create_effect_elrl_pos;
	sw_BR350_1_create_effect_by_railtype_third;
}

// Class 350/2 and /3+4 are overhead-only in this set.
// Uses the same panto car positions as /1.
switch(FEAT_TRAINS, SELF, sw_BR350_2_create_effect_elrl_pos_fwd, position_in_articulated_veh % 4) {
	2: electric_create_visual_effect;
	return 0;
}
switch(FEAT_TRAINS, SELF, sw_BR350_2_create_effect_elrl_pos_rev, position_in_articulated_veh % 4) {
	1: electric_create_visual_effect;
	return 0;
}
switch(FEAT_TRAINS, PARENT, sw_BR350_2_create_effect_elrl_pos, vehicle_is_reversed) {
	1: sw_BR350_2_create_effect_elrl_pos_rev;
	sw_BR350_2_create_effect_elrl_pos_fwd;
}

switch(FEAT_TRAINS, SELF, sw_BR350_1_create_effect_by_pos, position_in_articulated_veh % 4) {
	sw_BR350_1_create_effect_by_railtype;
}
switch(FEAT_TRAINS, SELF, sw_BR350_2_create_effect_by_pos, position_in_articulated_veh % 4) {
	sw_BR350_2_create_effect_elrl_pos;
}

// Purchase text helpers: show exact total seated capacity by current pax parameter.
// The purchase list's default capacity column rounds articulated values, so this
// keeps the true totals visible for each subclass.
switch(FEAT_TRAINS, SELF, sw_BR350_1_additional_text, param_pax) {
	1: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR350_usage),
			string(str_multiple_working_within_class),
			string(str_BR350_eos),
			string(str_BR350_1_capacity_1x),
			string(str_BR350_1_liveries)));
	2: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR350_usage),
			string(str_multiple_working_within_class),
			string(str_BR350_eos),
			string(str_BR350_1_capacity_2x),
			string(str_BR350_1_liveries)));
	3: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR350_usage),
			string(str_multiple_working_within_class),
			string(str_BR350_eos),
			string(str_BR350_1_capacity_3x),
			string(str_BR350_1_liveries)));
	4: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR350_usage),
			string(str_multiple_working_within_class),
			string(str_BR350_eos),
			string(str_BR350_1_capacity_4x),
			string(str_BR350_1_liveries)));
	return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR350_usage),
			string(str_multiple_working_within_class),
			string(str_BR350_eos),
			string(str_BR350_1_capacity_1x),
			string(str_BR350_1_liveries)));
}

