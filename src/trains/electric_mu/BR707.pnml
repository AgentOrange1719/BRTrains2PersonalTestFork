spriteset(spriteset_BR707_Purchase, "gfx/EMU/Desiro_City_WIP.png") {
	template_purchase(200, 26)
}

// Forward sprites by role/livery. A:A-cab, B:B-Cab, C:panto car (not used) D:middle trailer E:Middle trailer SE var2
spriteset(spriteset_BR707a_SWT, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old(0, 400) }
spriteset(spriteset_BR707b_SWT, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old(0, 500) }
spriteset(spriteset_BR707c_SWT, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old(0, 475) }
spriteset(spriteset_BR707d_SWT, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old(0, 450) }

spriteset(spriteset_BR707a_SE, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old(0, 550) }
spriteset(spriteset_BR707b_SE, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old(0, 675) }
spriteset(spriteset_BR707c_SE, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old(0, 350) }
spriteset(spriteset_BR707d_SE, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old(0, 600) }
spriteset(spriteset_BR707e_SE, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old(0, 625) }

// Reversed-template sprites by role/livery.
spriteset(spriteset_BR707a_SWT_rev, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old_reversed(0, 425) }
spriteset(spriteset_BR707b_SWT_rev, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old_reversed(0, 525) }
spriteset(spriteset_BR707c_SWT_rev, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old_reversed(0, 650) }
spriteset(spriteset_BR707d_SWT_rev, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old_reversed(0, 450) }

spriteset(spriteset_BR707a_SE_rev, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old_reversed(0, 575) }
spriteset(spriteset_BR707b_SE_rev, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old_reversed(0, 700) }
spriteset(spriteset_BR707c_SE_rev, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old_reversed(0, 650) }
spriteset(spriteset_BR707d_SE_rev, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old_reversed(0, 600) }
spriteset(spriteset_BR707e_SE_rev, "gfx/EMU/Desiro_City_WIP.png") { template_train32px_old_reversed(0, 625) }

// Role selectors (forward, by local cargo_subtype/livery).
switch(FEAT_TRAINS, SELF, sw_BR707a, cargo_subtype) {
	0: spriteset_BR707a_SWT;
	1: spriteset_BR707a_SE;
	default: spriteset_BR707a_SWT;
}

switch(FEAT_TRAINS, SELF, sw_BR707b, cargo_subtype) {
	0: spriteset_BR707b_SWT;
	1: spriteset_BR707b_SE;
	default: spriteset_BR707b_SWT;
}

//C car switch is set to d sprites, as panto is not currently used. May be used in future if converted to dual-voltage
switch(FEAT_TRAINS, SELF, sw_BR707c, cargo_subtype) {
	0: spriteset_BR707d_SWT;
	1: spriteset_BR707d_SE;
	default: spriteset_BR707c_SWT;
}

switch(FEAT_TRAINS, SELF, sw_BR707d, cargo_subtype) {
	0: spriteset_BR707d_SWT;
	1: spriteset_BR707d_SE;
	default: spriteset_BR707d_SWT;
}

// SE has a second middle-car variant here; SWT keeps the regular middle car.
switch(FEAT_TRAINS, SELF, sw_BR707e, cargo_subtype) {
	0: spriteset_BR707d_SWT;
	1: spriteset_BR707e_SE;
	default: spriteset_BR707d_SWT;
}

// Role selectors (reversed-template, using mirrored cargo_subtype from the opposite car).
switch(FEAT_TRAINS, SELF, sw_BR707a_rev, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR707a_SWT_rev;
	1: spriteset_BR707a_SE_rev;
	default: spriteset_BR707a_SWT_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR707b_rev, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR707b_SWT_rev;
	1: spriteset_BR707b_SE_rev;
	default: spriteset_BR707b_SWT_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR707c_rev, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR707d_SWT_rev;
	1: spriteset_BR707d_SE_rev;
	default: spriteset_BR707c_SWT_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR707d_rev, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR707d_SWT_rev;
	1: spriteset_BR707d_SE_rev;
	default: spriteset_BR707d_SWT_rev;
}

// SE has a second middle-car variant here; SWT keeps regular middle car.
switch(FEAT_TRAINS, SELF, sw_BR707e_rev, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR707d_SWT_rev;
	1: spriteset_BR707e_SE_rev;
	default: spriteset_BR707d_SWT_rev;
}

// 5-car Class 707 role order: A, C, E, D, B.
switch(FEAT_TRAINS, SELF, switch_BR707_roles_fwd, position_in_articulated_veh % 5) {
	0: sw_BR707a;
	1: sw_BR707c;
	2: sw_BR707e;
	3: sw_BR707d;
	4: sw_BR707b;
	sw_BR707d;
}

// Use mirrored articulated index for reverse mapping so external vehicles do not offset roles.
switch(FEAT_TRAINS, SELF, switch_BR707_roles_rev,
	[STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F),
		 var[0x61, 0, 0x000000FF, 0x41] % 5]) {
	0: sw_BR707a_rev;
	1: sw_BR707c_rev;
	2: sw_BR707e_rev;
	3: sw_BR707d_rev;
	4: sw_BR707b_rev;
	sw_BR707d_rev;
}

switch(FEAT_TRAINS, PARENT, switch_BR707_direction, vehicle_is_reversed) {
	1: switch_BR707_roles_rev;
	switch_BR707_roles_fwd;
}

switch(FEAT_TRAINS, SELF, switch_BR707_spriteset, cargo_subtype) {
	0: switch_BR707_direction;
	1: switch_BR707_direction;
	switch_BR707_direction;
}

switch(FEAT_TRAINS, SELF, switch_articulated_BR707, extra_callback_info1) {
	1..4: return item_BR707;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, sw_BR707_cargo_subtype_text, cargo_subtype) {
	0: return string(str_SWT);
	1: return string(str_Southeastern);
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_TRAINS, SELF, switch_BR707_can_attach_wagon, vehicle_type_id) {
	item_BR707: return CB_RESULT_ATTACH_ALLOW;
	item_BRMk2_Translator: return CB_RESULT_ATTACH_ALLOW;
	return string(STR_CANNOT_ATTACH);
}

switch(FEAT_TRAINS, SELF, switch_BR707_start_stop, num_vehs_in_consist) {
	return CB_RESULT_NO_TEXT;
}

// Third-rail effects on both driving cars.
switch(FEAT_TRAINS, SELF, switch_BR707_create_effect_pos_fwd, position_in_articulated_veh % 5) {
	0: electric_create_visual_effect_SAA3;
	4: electric_create_visual_effect_SAA3;
	return 0;
}

switch(FEAT_TRAINS, SELF, switch_BR707_create_effect_pos_rev,
		[STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F),
		 var[0x61, 0, 0x000000FF, 0x41] % 5]) {
	0: electric_create_visual_effect_SAA3;
	4: electric_create_visual_effect_SAA3;
	return 0;
}

switch(FEAT_TRAINS, PARENT, switch_BR707_create_effect_direction, vehicle_is_reversed) {
	1: switch_BR707_create_effect_pos_rev;
	switch_BR707_create_effect_pos_fwd;
}

// Capacity split totals:
// seated: 271
// seated + standing: 591
switch(FEAT_TRAINS, SELF, switch_BR707_cargo_capacity_seated, position_in_consist % 5) {
	0: return(55 * param_pax);
	1: return(54 * param_pax);
	2: return(53 * param_pax);
	3: return(54 * param_pax);
	4: return(55 * param_pax);
	return(54 * param_pax);
}

switch(FEAT_TRAINS, SELF, switch_BR707_cargo_capacity_high, position_in_consist % 5) {
	4: return(119 * param_pax);
	return(118 * param_pax);
}

switch(FEAT_TRAINS, SELF, switch_BR707_cargo_capacity, param_standing_capacity) {
	1: switch_BR707_cargo_capacity_high;
	switch_BR707_cargo_capacity_seated;
}

// Translator handling for Class 707:
// bit 0 in bitmask_vehicle_info marks translator wagons.
switch(FEAT_TRAINS, PARENT, switch_BR707_power_with_translator, (bitmask_consist_info & 0x01)) {
	0: return 2750;
	return 0;
}

switch(FEAT_TRAINS, PARENT, switch_BR707_te_with_translator, (bitmask_consist_info & 0x01)) {
	0: return 38; // 0.15 * 255
	return 0;
}

switch(FEAT_TRAINS, PARENT, switch_BR707_cargo_capacity_with_translator, (bitmask_consist_info & 0x01)) {
	0: switch_BR707_cargo_capacity;
	return 0;
}

switch(FEAT_TRAINS, SELF, switch_sound_electric_707_muted, getbits(extra_callback_info1, 0, 8)) {
	SOUND_EVENT_BREAKDOWN: SOUND_BREAKDOWN_TRAIN_SHIP;
}

switch(FEAT_TRAINS, PARENT, switch_sound_electric_707_with_translator, (bitmask_consist_info & 0x01)) {
	0: sw_sound_electric_350;
	switch_sound_electric_707_muted;
}

switch(FEAT_TRAINS, PARENT, switch_BR707_create_effect_with_translator, (bitmask_consist_info & 0x01)) {
	0: switch_BR707_create_effect_direction;
	return 0;
}

switch(FEAT_TRAINS, SELF, switch_BR707_additional_text, param_standing_capacity * 10 + param_pax) {
	1: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR707_usage),
			string(str_multiple_working_within_class),
			string(str_BR707_eos),
			string(str_BR707_capacity_1x),
			string(str_BR707_liveries)));
	2: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR707_usage),
			string(str_multiple_working_within_class),
			string(str_BR707_eos),
			string(str_BR707_capacity_2x),
			string(str_BR707_liveries)));
	3: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR707_usage),
			string(str_multiple_working_within_class),
			string(str_BR707_eos),
			string(str_BR707_capacity_3x),
			string(str_BR707_liveries)));
	4: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR707_usage),
			string(str_multiple_working_within_class),
			string(str_BR707_eos),
			string(str_BR707_capacity_4x),
			string(str_BR707_liveries)));
	11: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR707_usage),
			string(str_multiple_working_within_class),
			string(str_BR707_eos),
			string(str_BR707_capacity_hc_1x),
			string(str_BR707_liveries)));
	12: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR707_usage),
			string(str_multiple_working_within_class),
			string(str_BR707_eos),
			string(str_BR707_capacity_hc_2x),
			string(str_BR707_liveries)));
	13: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR707_usage),
			string(str_multiple_working_within_class),
			string(str_BR707_eos),
			string(str_BR707_capacity_hc_3x),
			string(str_BR707_liveries)));
	14: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR707_usage),
			string(str_multiple_working_within_class),
			string(str_BR707_eos),
			string(str_BR707_capacity_hc_4x),
			string(str_BR707_liveries)));
	return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR707_usage),
			string(str_multiple_working_within_class),
			string(str_BR707_eos),
			string(str_BR707_capacity_1x),
			string(str_BR707_liveries)));
}

item(FEAT_TRAINS, item_BR707, 514) {
	property {
		variant_group:                 header_DesiroCity;
		name:                          string(STR_NAME_BR707);
		climates_available:            ALL_CLIMATES;
		introduction_date:             date(2015,4,21);
		model_life:                    15;
		retire_early:                  1;
		vehicle_life:                  50;
		reliability_decay:             7;
		refittable_cargo_classes:      CC_PASSENGERS;
		cargo_allow_refit:             [PASS, TOUR];
		loading_speed:                 25;
		cost_factor:                   123;
		running_cost_factor:           70;
		sprite_id:                     SPRITE_ID_NEW_TRAIN;
		speed:                         100 mph;
		refit_cost:                    0;
		track_type:                    THIRD;
		ai_special_flag:               AI_FLAG_CARGO;
		power:                         2750 hp;
		running_cost_base:             RUNNING_COST_ELECTRIC;
		misc_flags:                    TRAIN_FLAG_MU;
		dual_headed:                   0;
		default_cargo_type:            PASS;
		cargo_capacity:                54;
		weight:                        306 ton;
		engine_class:                  ENGINE_CLASS_ELECTRIC;
		tractive_effort_coefficient:   0.15;
		air_drag_coefficient:          0.05;
		length:                        8;
		effect_spawn_model_and_powered:EFFECT_SPAWN_MODEL_ELECTRIC;
		extra_weight_per_wagon:        0;
		bitmask_vehicle_info:          0;
	}
	graphics {
		additional_text:               switch_BR707_additional_text;
		can_attach_wagon:              switch_BR707_can_attach_wagon;
		cargo_subtype_text:            sw_BR707_cargo_subtype_text;
		articulated_part:              switch_articulated_BR707;
		start_stop:                    switch_BR707_start_stop;
		default:                       switch_BR707_spriteset;
		purchase:                      spriteset_BR707_Purchase;
		create_effect:                 switch_BR707_create_effect_with_translator;
		colour_mapping:                return PALETTE_CC_FIRST;
		sound_effect:                  switch_sound_electric_707_with_translator;
		power:                         switch_BR707_power_with_translator;
		tractive_effort_coefficient:   switch_BR707_te_with_translator;
		cargo_capacity:                switch_BR707_cargo_capacity_with_translator;
		cost_factor:                   return(GetAdjustedCost(123));
		running_cost_factor:           return(GetAdjustedCost(70));
	}
}

