// Define articulations
switch(FEAT_TRAINS, SELF, switch_br_331_0_articulated, extra_callback_info1) {
	1..2: return item_br_331_0;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, switch_br_331_0_roles_fwd_local, position_in_articulated_veh % 3) {
	0: spriteset_br_195_331_front;
	2: spriteset_br_195_331_rear;
	spriteset_br_331_middle_panto;
}

switch(FEAT_TRAINS, SELF, switch_br_331_0_rev_role_3car_local, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x000000FF, 0x41] % 3]) {
	0: spriteset_br_195_331_front_rev;
	2: spriteset_br_195_331_rear_rev;
	spriteset_br_331_middle_panto_rev;
}

switch(FEAT_TRAINS, SELF, switch_br_331_0_rev_role_4car_local, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x000000FF, 0x41] % 4]) {
	0: spriteset_br_195_331_front_rev;
	1: spriteset_br_331_middle_panto_rev;
	2: spriteset_br_195_331_middle_rev;
	3: spriteset_br_195_331_rear_rev;
	spriteset_br_195_331_middle_rev;
}

switch(FEAT_TRAINS, SELF, switch_br_331_0_rev_from_mirror_local, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xC6]]) {
	424: switch_br_331_0_rev_role_3car_local;
	2424: switch_br_331_0_rev_role_3car_local;
	425: switch_br_331_0_rev_role_4car_local;
	2425: switch_br_331_0_rev_role_4car_local;
	switch_br_331_0_rev_role_3car_local;
}

switch(FEAT_TRAINS, PARENT, switch_br_331_0_direction_local, vehicle_is_reversed) {
	1: switch_br_331_0_rev_from_mirror_local;
	switch_br_331_0_roles_fwd_local;
}

// Only give particle effects to middle/pantograph car
switch(FEAT_TRAINS, SELF, switch_br_331_0_particles, position_in_articulated_veh % 3) {
	1: visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 2, DISABLE_WAGON_POWER);
	visual_effect_and_powered(VISUAL_EFFECT_DISABLE, 0, DISABLE_WAGON_POWER);
}

// Start/stop switch, used to limit maximum length
switch(FEAT_TRAINS, SELF, switch_br_331_0_start_stop, num_vehs_in_consist) {
	return CB_RESULT_NO_TEXT;
}

// Only allow the same train type to be added to itself
switch(FEAT_TRAINS, SELF, switch_br_331_0_can_attach_wagon, vehicle_type_id) {
	item_br_331_0: return CB_RESULT_ATTACH_ALLOW;
	item_br_331_1: return CB_RESULT_ATTACH_ALLOW;
	return string(STR_CANNOT_ATTACH);
}
switch(FEAT_TRAINS, SELF, switch_br_331_0_capacity, position_in_articulated_veh % 3) {
	return(68 * param_pax);
}


switch(FEAT_TRAINS, SELF, switch_br_331_0_additional_text, param_pax) {
	1: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR331_usage),
			string(str_multiple_working_within_class),
			string(str_BR331_eos),
			string(str_BR331_0_capacity_1x),
			string(str_BR331_liveries)));
	2: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR331_usage),
			string(str_multiple_working_within_class),
			string(str_BR331_eos),
			string(str_BR331_0_capacity_2x),
			string(str_BR331_liveries)));
	3: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR331_usage),
			string(str_multiple_working_within_class),
			string(str_BR331_eos),
			string(str_BR331_0_capacity_3x),
			string(str_BR331_liveries)));
	4: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR331_usage),
			string(str_multiple_working_within_class),
			string(str_BR331_eos),
			string(str_BR331_0_capacity_4x),
			string(str_BR331_liveries)));
	return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR331_usage),
			string(str_multiple_working_within_class),
			string(str_BR331_eos),
			string(str_BR331_0_capacity_1x),
			string(str_BR331_liveries)));
}

// Class 331/0 (3car)
item(FEAT_TRAINS, item_br_331_0, 424) {
	property {
		variant_group:					header_Civity;
		name: string(STR_BR_331_3CAR);
		climates_available: ALL_CLIMATES;
		introduction_date: date(2019, 07, 01);
		model_life: VEHICLE_NEVER_EXPIRES;
		vehicle_life: 35;
		reliability_decay: 0;
		refittable_cargo_classes: bitmask(CC_PASSENGERS);
		non_refittable_cargo_classes: bitmask();
		cost_factor: 62;
		loading_speed: 25;
		running_cost_factor: 33;
		cargo_allow_refit: [];
		cargo_disallow_refit: [];

		speed: 100 mph;
		power: 2360 hp;
		cargo_capacity: 68;
		weight: 128.0 ton;

		sprite_id: SPRITE_ID_NEW_TRAIN;
		refit_cost: 0;
		track_type: ELRL;
		ai_special_flag: AI_FLAG_PASSENGER;
		running_cost_base: RUNNING_COST_ELECTRIC;
		dual_headed: 0;
		engine_class: ENGINE_CLASS_ELECTRIC;
		extra_power_per_wagon: 0 kW;
		tractive_effort_coefficient: 0.3;
		air_drag_coefficient: 0.06;
		length: 8;
		visual_effect_and_powered: visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 2, DISABLE_WAGON_POWER);
		extra_weight_per_wagon: 0 ton;
		bitmask_vehicle_info: 0;
	}

	graphics {
		default: switch_br_331_0_direction_local;
		purchase: spriteset_br_331_purchase;

		articulated_part: switch_br_331_0_articulated;
		start_stop: switch_br_331_0_start_stop;
		can_attach_wagon: switch_br_331_0_can_attach_wagon;
		visual_effect_and_powered: switch_br_331_0_particles;
		power: return 2360;
		tractive_effort_coefficient: return 76;
		cargo_capacity: switch_br_331_0_capacity;
		additional_text: switch_br_331_0_additional_text;
		cost_factor: return(GetAdjustedCost(62));
		running_cost_factor: return(GetAdjustedCost(33));
	}
}
