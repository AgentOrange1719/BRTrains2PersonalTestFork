// Define articulations
switch(FEAT_TRAINS, SELF, switch_br_397_articulated, extra_callback_info1) {
	1..4: return item_br_397;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// Only give particle effects to middle/pantograph car
switch(FEAT_TRAINS, SELF, switch_br_397_particles, position_in_articulated_veh % 5) {
	3: visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 2, DISABLE_WAGON_POWER);
	visual_effect_and_powered(VISUAL_EFFECT_DISABLE, 0, DISABLE_WAGON_POWER);
}

// Start/stop switch, used to limit maximum length
switch(FEAT_TRAINS, SELF, switch_br_397_start_stop, num_vehs_in_consist) {
	return CB_RESULT_NO_TEXT;
}

// Only allow the same train type to be added to itself
switch(FEAT_TRAINS, SELF, switch_br_397_can_attach_wagon, vehicle_type_id) {
	item_br_397: return CB_RESULT_ATTACH_ALLOW;
	item_BRMk2_Translator: return CB_RESULT_ATTACH_ALLOW;
	return string(STR_CANNOT_ATTACH);
}

switch(FEAT_TRAINS, PARENT, switch_br_397_power_with_translator, (bitmask_consist_info & 0x01)) {
	0: return 3400;
	return 0;
}

switch(FEAT_TRAINS, PARENT, switch_br_397_te_with_translator, (bitmask_consist_info & 0x01)) {
	0: return 76; // 0.30 * 255
	return 0;
}

switch(FEAT_TRAINS, SELF, switch_br_397_capacity, position_in_articulated_veh % 5) {
	return ((286 / 5) * param_pax);
}

switch(FEAT_TRAINS, PARENT, switch_br_397_capacity_with_translator, (bitmask_consist_info & 0x01)) {
	0: switch_br_397_capacity;
	return 0;
}

switch(FEAT_TRAINS, PARENT, switch_br_397_particles_with_translator, (bitmask_consist_info & 0x01)) {
	0: switch_br_397_particles;
	visual_effect_and_powered(VISUAL_EFFECT_DISABLE, 0, DISABLE_WAGON_POWER);
}

switch(FEAT_TRAINS, SELF, switch_br_397_additional_text, cargo_subtype) {
	return(string(str_purchase_loco_with_liveries_and_mw,
			string(str_purchase_type_emu),
			string(str_BR397_usage),
			string(str_multiple_working_within_class),
			string(str_BR397_eos),
			string(str_BR397_liveries)));
}

// Class 397 (5 car)
item(FEAT_TRAINS, item_br_397, 427) {
	property {
		variant_group:					header_Civity;
		name: string(STR_BR_397);
		climates_available: ALL_CLIMATES;
		introduction_date: date(2019, 11, 30);
		model_life: VEHICLE_NEVER_EXPIRES;
		vehicle_life: 35;
		reliability_decay: 0;
		refittable_cargo_classes: bitmask(CC_PASSENGERS);
		non_refittable_cargo_classes: bitmask();
		cost_factor: 76;
		loading_speed: 15;
		running_cost_factor: 40;
		cargo_allow_refit: [];
		cargo_disallow_refit: [];

		speed: 125 mph;
		power: 3400 hp;
		cargo_capacity: (286 / 5);
		weight: 192.5 ton;

		sprite_id: SPRITE_ID_NEW_TRAIN;
		refit_cost: 0;
		track_type: ELRL;
		ai_special_flag: AI_FLAG_PASSENGER;
		running_cost_base: RUNNING_COST_ELECTRIC;
		dual_headed: 0;
		engine_class: ENGINE_CLASS_ELECTRIC;
		extra_power_per_wagon: 0 kW;
		tractive_effort_coefficient: 0.3;
		air_drag_coefficient: 0.06;
		length: 8;
		visual_effect_and_powered: visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 2, DISABLE_WAGON_POWER);
		extra_weight_per_wagon: 0 ton;
		bitmask_vehicle_info: 0;
	}

	graphics {
		default: sw_BR397_direction;
		purchase: spriteset_br_397_purchase;

		articulated_part: switch_br_397_articulated;
		start_stop: switch_br_397_start_stop;
		can_attach_wagon: switch_br_397_can_attach_wagon;
		visual_effect_and_powered: switch_br_397_particles_with_translator;
		power: switch_br_397_power_with_translator;
		tractive_effort_coefficient: switch_br_397_te_with_translator;
		cargo_capacity: switch_br_397_capacity_with_translator;
		additional_text: switch_br_397_additional_text;
		cost_factor: return(GetAdjustedCost(76));
		running_cost_factor: return(GetAdjustedCost(40));
	}
}
