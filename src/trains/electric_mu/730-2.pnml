// ============================================================================
// Class 730/2 unit definition (5-car articulated set)
// ============================================================================

switch(FEAT_TRAINS, SELF, switch_br730_2_subtype_text, cargo_subtype) {
	0: return string(str_LNWR);	
	return CB_RESULT_NO_TEXT;
}

// Build fixed 5-car units by returning the same item ID for articulated cars 1..4.
switch(FEAT_TRAINS, SELF, switch_br730_2_articulated, extra_callback_info1) {
	1..4: return item_br730_2;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// Effects are emitted from the middle panto car only.
switch(FEAT_TRAINS, SELF, switch_br730_2_effect_pos, position_in_articulated_veh % 5) {
	2: visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC	, 2, DISABLE_WAGON_POWER);
	visual_effect_and_powered(VISUAL_EFFECT_DISABLE, 0, DISABLE_WAGON_POWER);
}

// Translator handling:
// Bit 0 in bitmask_vehicle_info marks translator wagons.
switch(FEAT_TRAINS, PARENT, switch_br730_2_power_with_translator, (bitmask_consist_info & 0x01)) {
	0: return 4200;
	return 0;
}

switch(FEAT_TRAINS, PARENT, switch_br730_2_te_with_translator, (bitmask_consist_info & 0x01)) {
	0: return 76; // 0.30 * 255
	return 0;
}

// Capacity split for Class 730/2:
// seated total = 369
// expanded-unit standing mode total = 571 (param_standing_capacity == 2 only)
switch(FEAT_TRAINS, SELF, switch_br730_2_capacity_seated, position_in_articulated_veh % 5) {
	2: return(73 * param_pax);
	return(74 * param_pax);
}

switch(FEAT_TRAINS, SELF, switch_br730_2_capacity_high_expanded, position_in_articulated_veh % 5) {
	2: return(115 * param_pax);
	return(114 * param_pax);
}

switch(FEAT_TRAINS, SELF, switch_br730_2_capacity_by_mode, param_standing_capacity) {
	2: switch_br730_2_capacity_high_expanded;
	switch_br730_2_capacity_seated;
}

switch(FEAT_TRAINS, PARENT, switch_br730_2_capacity_with_translator, (bitmask_consist_info & 0x01)) {
	0: switch_br730_2_capacity_by_mode;
	return 0;
}

switch(FEAT_TRAINS, SELF, switch_sound_electric_730_2_muted, getbits(extra_callback_info1, 0, 8)) {
	SOUND_EVENT_BREAKDOWN: SOUND_BREAKDOWN_TRAIN_SHIP;
}

switch(FEAT_TRAINS, PARENT, switch_sound_electric_730_2_with_translator, (bitmask_consist_info & 0x01)) {
	0: sw_sound_electric_350;
	switch_sound_electric_730_2_muted;
}

switch(FEAT_TRAINS, PARENT, switch_br730_2_effect_with_translator, (bitmask_consist_info & 0x01)) {
	0: switch_br730_2_effect_pos;
	visual_effect_and_powered(VISUAL_EFFECT_DISABLE, 0, DISABLE_WAGON_POWER);
}

// Multiple working limit: maximum 10 cars in the complete consist.
switch(FEAT_TRAINS, SELF, switch_br730_2_start_stop, num_vehs_in_consist) {	
	1..10: return CB_RESULT_NO_TEXT;
	return string(STR_BR_730_MW_LIMIT);
}

// Allow coupling between 730/0 and 730/2 units, plus translator wagons.
switch(FEAT_TRAINS, SELF, switch_br730_2_can_attach_wagon, vehicle_type_id) {
	item_br730_0: return CB_RESULT_ATTACH_ALLOW;
	item_br730_2: return CB_RESULT_ATTACH_ALLOW;
	item_BRMk2_Translator: return CB_RESULT_ATTACH_ALLOW;
	return string(STR_CANNOT_ATTACH);
}

// Purchase text helper:
// Class 730/2 only uses high-capacity values in expanded standing-room mode.
switch(FEAT_TRAINS, SELF, switch_br730_2_additional_text, (param_standing_capacity == 2) * 10 + param_pax) {
	1: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR730_usage),
			string(str_multiple_working_within_class),
			string(str_BR730_eos),
			string(str_BR730_2_capacity_1x),
			string(str_BR730_2_liveries)));
	2: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR730_usage),
			string(str_multiple_working_within_class),
			string(str_BR730_eos),
			string(str_BR730_2_capacity_2x),
			string(str_BR730_2_liveries)));
	3: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR730_usage),
			string(str_multiple_working_within_class),
			string(str_BR730_eos),
			string(str_BR730_2_capacity_3x),
			string(str_BR730_2_liveries)));
	4: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR730_usage),
			string(str_multiple_working_within_class),
			string(str_BR730_eos),
			string(str_BR730_2_capacity_4x),
			string(str_BR730_2_liveries)));
	11: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR730_usage),
			string(str_multiple_working_within_class),
			string(str_BR730_eos),
			string(str_BR730_2_capacity_hc_1x),
			string(str_BR730_2_liveries)));
	12: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR730_usage),
			string(str_multiple_working_within_class),
			string(str_BR730_eos),
			string(str_BR730_2_capacity_hc_2x),
			string(str_BR730_2_liveries)));
	13: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR730_usage),
			string(str_multiple_working_within_class),
			string(str_BR730_eos),
			string(str_BR730_2_capacity_hc_3x),
			string(str_BR730_2_liveries)));
	14: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR730_usage),
			string(str_multiple_working_within_class),
			string(str_BR730_eos),
			string(str_BR730_2_capacity_hc_4x),
			string(str_BR730_2_liveries)));
	return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR730_usage),
			string(str_multiple_working_within_class),
			string(str_BR730_eos),
			string(str_BR730_2_capacity_1x),
			string(str_BR730_2_liveries)));
}


item(FEAT_TRAINS, item_br730_2, 576) {
	property {
		variant_group:					header_Aventra;
		name: string(STR_BR730_2);
		climates_available: ALL_CLIMATES; // available in all climates
		introduction_date: date(2024, 03, 17);
		model_life: VEHICLE_NEVER_EXPIRES; // keep available forever		
		vehicle_life: 30; // years after vehicle is deemed "old" and should be replaced
		reliability_decay: 0; // dont reduce reliabilty, (will grow from 75% upwards over the years)
		refittable_cargo_classes: bitmask(CC_PASSENGERS);
		non_refittable_cargo_classes: bitmask();
		cost_factor: 170;
		loading_speed: 25;
		running_cost_factor: 100;
		cargo_allow_refit: [];
		cargo_disallow_refit: [];
		
		speed: 110 mph;
		power: 4200 hp;
		cargo_capacity: 74;
		weight: 330 ton;
		
		sprite_id: SPRITE_ID_NEW_TRAIN; // required
		refit_cost: 0;
		track_type: railtype("ELRL");
		ai_special_flag: AI_FLAG_PASSENGER; // tell ai that this is a passenger train
		running_cost_base: RUNNING_COST_ELECTRIC;
		misc_flags: TRAIN_FLAG_MU;
		dual_headed: 0; // set to 0 otherwise limited to 2 cars only
		engine_class: ENGINE_CLASS_ELECTRIC; // even if its 3rd rail, ELECTRIC would give overhead wire effects
		extra_power_per_wagon: 0 kW;
		tractive_effort_coefficient: 0.3;
		air_drag_coefficient: 0.06;
		length: 8; // full tile length vehicle
		visual_effect_and_powered: visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 2, DISABLE_WAGON_POWER); // visual fx
		extra_weight_per_wagon: 0 ton;
		bitmask_vehicle_info: 0;
	}
	
	graphics {
		default: switch_br730_2_spriteset;
		purchase: spriteset_br730_2_purchase;
		cargo_subtype_text: switch_br730_2_subtype_text;
		
		articulated_part: switch_br730_2_articulated;
		start_stop: switch_br730_2_start_stop;	
		can_attach_wagon: switch_br730_2_can_attach_wagon;
		visual_effect_and_powered: switch_br730_2_effect_with_translator;
		additional_text: switch_br730_2_additional_text;
		sound_effect: switch_sound_electric_730_2_with_translator;
		power: switch_br730_2_power_with_translator;
		tractive_effort_coefficient: switch_br730_2_te_with_translator;
		cargo_capacity: switch_br730_2_capacity_with_translator;
		cost_factor:	return(GetAdjustedCost(170));
		running_cost_factor: return(GetAdjustedCost(100));
	}
}
