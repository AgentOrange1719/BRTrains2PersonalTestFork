	3: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw, string(str_purchase_type_emu), string(str_BR319_usage), string(str_multiple_working_within_class), string(str_BR319_eos), string(str_BR319_2_capacity_3x), string(str_BR319_liveries)));
	4: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw, string(str_purchase_type_emu), string(str_BR319_usage), string(str_multiple_working_within_class), string(str_BR319_eos), string(str_BR319_2_capacity_4x), string(str_BR319_liveries)));
