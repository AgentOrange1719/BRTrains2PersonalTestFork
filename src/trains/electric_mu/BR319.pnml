		default: sw_BR319_direction;
		purchase: spriteset_BR319_Purchase;
		colour_mapping: return PALETTE_CC_FIRST;
		create_effect: sw_BR319_create_effect;
		sound_effect: sw_sound_electric_GEC;
		cargo_capacity: sw_BR319_4_capacity;
		cost_factor: return(GetAdjustedCost(61));
		running_cost_factor: return(GetAdjustedCost(37));
	}
}
