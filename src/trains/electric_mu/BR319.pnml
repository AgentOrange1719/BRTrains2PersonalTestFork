//This file defines the Class 319 EMU, including all subclasses.

//Build the vehicles: These vehicles are defined as a single vehicle-id per subclass articulated vehicle. These switches build the vehicle, stopping at 4 total cars.
switch(FEAT_TRAINS, SELF, sw_articulated_BR319_0, extra_callback_info1) {
	1..3: return item_BR319;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, sw_articulated_BR319_1, extra_callback_info1) {
	1..3: return item_BR319_1;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, sw_articulated_BR319_2, extra_callback_info1) {
	1..3: return item_BR319_2;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, sw_articulated_BR319_3, extra_callback_info1) {
	1..3: return item_BR319_3;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, sw_articulated_BR319_4, extra_callback_info1) {
	1..3: return item_BR319_4;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

//Choose liveries (cargo_subtype). Currently all liveries are avalivle to all subclasses pending verification of exactly which liveries each class actually wore at some point. 
//Each subclass will need a decicated chain then, but for now can share one.
switch(FEAT_TRAINS, SELF, sw_BR319_cargo_subtype_text, cargo_subtype) {
	0: return string(str_NSE);
	1: return string(str_thameslink);
	2: return string(str_Connex);
	3: return string(str_fcc);
	4: return string(str_gtrp);
	5: return string(str_gtrb);
	6: return string(str_Southern);
	7: return string(str_Northern);
	8: return string(str_LondonMidland);
	return CB_RESULT_NO_TEXT;
}

//Set total cargo capacity. These switches are needed because by default the game will set the capacity of an articulated vehicle by multiplying the capacity of the first car by the number of wagons, so the total can only be a multiple of the number of cars, unless these switches are present.
//Numbers are seats only, sourced from https://web.archive.org/web/20070927210506/http://www.therailwaycentre.com/Recognition%20Tech%20Data%20EMU/EMU_319.html
// 319/0 subclass
switch(FEAT_TRAINS, SELF, sw_BR319_0_capacity, position_in_articulated_veh % 4) {
	0: return(80 * param_pax);
	1: return(80 * param_pax);
	2: return(80 * param_pax);
	3: return(79 * param_pax);
	return(80 * param_pax);
}
// 319/1 subclass
switch(FEAT_TRAINS, SELF, sw_BR319_1_capacity, position_in_articulated_veh % 4) {
	0: return(78 * param_pax);
	1: return(78 * param_pax);
	2: return(78 * param_pax);
	3: return(77 * param_pax);
	return(78 * param_pax);
}
// 319/2 subclass
switch(FEAT_TRAINS, SELF, sw_BR319_2_capacity, position_in_articulated_veh % 4) {
	0: return(58 * param_pax);
	1: return(58 * param_pax);
	2: return(57 * param_pax);
	3: return(57 * param_pax);
	return(58 * param_pax);
}
// 319/3 subclass
switch(FEAT_TRAINS, SELF, sw_BR319_3_capacity, position_in_articulated_veh % 4) {
	0: return(77 * param_pax);
	1: return(77 * param_pax);
	2: return(77 * param_pax);
	3: return(77 * param_pax);
	return(77 * param_pax);
}
// 319/4 subclass
switch(FEAT_TRAINS, SELF, sw_BR319_4_capacity, position_in_articulated_veh % 4) {
	0: return(72 * param_pax);
	1: return(73 * param_pax);
	2: return(72 * param_pax);
	3: return(72 * param_pax);
	return(72 * param_pax);
}

//Additional text for purchase menu, showing actual capacity since the default capacity line will only display the first car's capacity multiplies by the number of cars.
switch(FEAT_TRAINS, SELF, sw_BR319_0_additional_text, param_pax) {
	1: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw, string(str_purchase_type_emu), string(str_BR319_usage), string(str_multiple_working_within_class), string(str_BR319_eos), string(str_BR319_0_capacity_1x), string(str_BR319_liveries)));
	2: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw, string(str_purchase_type_emu), string(str_BR319_usage), string(str_multiple_working_within_class), string(str_BR319_eos), string(str_BR319_0_capacity_2x), string(str_BR319_liveries)));
	3: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw, string(str_purchase_type_emu), string(str_BR319_usage), string(str_multiple_working_within_class), string(str_BR319_eos), string(str_BR319_0_capacity_3x), string(str_BR319_liveries)));
	4: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw, string(str_purchase_type_emu), string(str_BR319_usage), string(str_multiple_working_within_class), string(str_BR319_eos), string(str_BR319_0_capacity_4x), string(str_BR319_liveries)));
	return(string(str_purchase_loco_with_liveries_and_capacity_and_mw, string(str_purchase_type_emu), string(str_BR319_usage), string(str_multiple_working_within_class), string(str_BR319_eos), string(str_BR319_0_capacity_1x), string(str_BR319_liveries)));
}

switch(FEAT_TRAINS, SELF, sw_BR319_1_additional_text, param_pax) {
	1: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw, string(str_purchase_type_emu), string(str_BR319_usage), string(str_multiple_working_within_class), string(str_BR319_eos), string(str_BR319_1_capacity_1x), string(str_BR319_liveries)));
