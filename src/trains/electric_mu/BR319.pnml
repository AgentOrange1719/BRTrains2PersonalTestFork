}

//This block of switches chooses which visual effects to show and from which cars. OHLE effects preferred if both OHL and 3rd rail are present.
switch(FEAT_TRAINS, SELF, sw_BR319_create_effect_elrl_pos_fwd, position_in_articulated_veh % 4) {
	2: electric_create_visual_effect;
	return 0;
}

switch(FEAT_TRAINS, SELF, sw_BR319_create_effect_elrl_pos_rev, position_in_articulated_veh % 4) {
	1: electric_create_visual_effect;
	return 0;
}

switch(FEAT_TRAINS, PARENT, sw_BR319_create_effect_elrl_pos, vehicle_is_reversed) {
	1: sw_BR319_create_effect_elrl_pos_rev;
	sw_BR319_create_effect_elrl_pos_fwd;
}

switch(FEAT_TRAINS, SELF, sw_BR319_create_effect_third_pos, position_in_articulated_veh % 4) {
	0: electric_create_visual_effect_SAA3;
	3: electric_create_visual_effect_SAA3;
	return 0;
}

switch(FEAT_TRAINS, PARENT, sw_BR319_create_effect_by_railtype_third, tile_powers_railtype("THIRD")) {
	1: sw_BR319_create_effect_third_pos;
	return 0;
}

switch(FEAT_TRAINS, PARENT, sw_BR319_create_effect, tile_powers_railtype("ELRL")) {
	1: sw_BR319_create_effect_elrl_pos;
	sw_BR319_create_effect_by_railtype_third;
}

//Limit of 3 units (3 units x 4 cars each) attatched
switch(FEAT_TRAINS, SELF, sw_BR319_start_stop, num_vehs_in_consist) {
	1..12: return CB_RESULT_NO_TEXT;
	return string(STR_BR_319_MW_LIMIT);
}

//Only allow the Class 319 to couple to other Class 319s, regardless of subclass
switch(FEAT_TRAINS, SELF, sw_BR319_can_attach_wagon, vehicle_type_id) {
	item_BR319: return CB_RESULT_ATTACH_ALLOW;
	item_BR319_1: return CB_RESULT_ATTACH_ALLOW;
	item_BR319_2: return CB_RESULT_ATTACH_ALLOW;
	item_BR319_3: return CB_RESULT_ATTACH_ALLOW;
	item_BR319_4: return CB_RESULT_ATTACH_ALLOW;
	return string(STR_CANNOT_ATTACH);
}

//Class 319/0 item block
item(FEAT_TRAINS, item_BR319, 248) {
	property {
		name: string(STR_NAME_BR319_0);
		variant_group: header_BR319;
		climates_available: ALL_CLIMATES;
		introduction_date: date(1987, 4, 21);
		model_life: 15;
		retire_early: 1;
		vehicle_life: 50;
		reliability_decay: 7;
		refittable_cargo_classes: CC_PASSENGERS;
		cargo_allow_refit: [PASS, TOUR];
		loading_speed: 25;
		cost_factor: 61;
		running_cost_factor: 37;
		sprite_id: SPRITE_ID_NEW_TRAIN;
		speed: 100 mph;
		refit_cost: 0;
		track_type: [THIRD, THIRD, ELRL];
		ai_special_flag: AI_FLAG_CARGO;
		power: 1438 hp;
		running_cost_base: RUNNING_COST_ELECTRIC;
		dual_headed: 0;
		default_cargo_type: PASS;
		cargo_capacity: 80;
		weight: 168 ton;
		engine_class: ENGINE_CLASS_ELECTRIC;
		tractive_effort_coefficient: 0.08;
		air_drag_coefficient: 0.05;
		length: 8;
		effect_spawn_model_and_powered: EFFECT_SPAWN_MODEL_ELECTRIC;
		extra_weight_per_wagon: 0;
		bitmask_vehicle_info: 0;
		cargo_age_period: 185;
	}
	graphics {
		additional_text: sw_BR319_0_additional_text;
		can_attach_wagon: sw_BR319_can_attach_wagon;
		start_stop: sw_BR319_start_stop;
		cargo_subtype_text: sw_BR319_cargo_subtype_text;
		articulated_part: sw_articulated_BR319_0;
		default: sw_BR319_direction;
		purchase: spriteset_BR319_Purchase;
		colour_mapping: return PALETTE_CC_FIRST;
		create_effect: sw_BR319_create_effect;
		sound_effect: sw_sound_electric_GEC;
		cargo_capacity: sw_BR319_0_capacity;
		cost_factor: return(GetAdjustedCost(61));
		running_cost_factor: return(GetAdjustedCost(37));
	}
}

