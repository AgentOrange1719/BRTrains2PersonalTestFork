// ============================================================================
// CLASS 350/1  -  subtype: 0=LM  1=Silverlink  2=LNWR Trans  3=LNWR Full
//                          4=LNWR Ukraine
// ============================================================================

// Forward: cargo_subtype selects the livery spriteset for each car position.
switch(FEAT_TRAINS, SELF, sw_BR350_1a, cargo_subtype) {
	0: sw_BR350a_LM_loading_mode;          1: sw_BR350a_SLinkCentral_loading_mode;
	2: sw_BR350a_LNWRSimple_loading_mode;  3: sw_BR350a_LNWRFull_loading_mode;
	4: sw_BR350a_LNWRUkraine_loading_mode;
	default: sw_BR350a_LM_loading_mode;
}
switch(FEAT_TRAINS, SELF, sw_BR350_1b, cargo_subtype) {
	0: sw_BR350b_LM_loading_mode;          1: sw_BR350b_SLinkCentral_loading_mode;
	2: sw_BR350b_LNWRSimple_loading_mode;  3: sw_BR350b_LNWRFull_loading_mode;
	4: sw_BR350b_LNWRUkraine_loading_mode;
	default: sw_BR350b_LM_loading_mode;
}
switch(FEAT_TRAINS, SELF, sw_BR350_1c, cargo_subtype) {
	0: sw_BR350c_LM_loading_mode;          1: sw_BR350c_SLinkCentral_loading_mode;
	2: sw_BR350c_LNWRSimple_loading_mode;  3: sw_BR350c_LNWRFull_loading_mode;
	4: sw_BR350c_LNWRUkraine_loading_mode;
	default: sw_BR350c_LM_loading_mode;
}
switch(FEAT_TRAINS, SELF, sw_BR350_1d, cargo_subtype) {
	0: sw_BR350d_LM_loading_mode;          1: sw_BR350d_SLinkCentral_loading_mode;
	2: sw_BR350d_LNWRSimple_loading_mode;  3: sw_BR350d_LNWRFull_loading_mode;
	4: sw_BR350d_LNWRUkraine_loading_mode;
	default: sw_BR350d_LM_loading_mode;
}

// Reversed: reads cargo_subtype from the geographically-equivalent forward car.
// Each switch re-stores the same mirror offset into temp register 0x10F before
// reading var[0x61, ..., 0xF2] from the mirrored vehicle.
switch(FEAT_TRAINS, SELF, sw_BR350_1a_rev, [STORE_TEMP(position_in_consist_from_end-position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: sw_BR350a_LM_rev_loading_mode;          1: sw_BR350a_SLinkCentral_rev_loading_mode;
	2: sw_BR350a_LNWRSimple_rev_loading_mode;  3: sw_BR350a_LNWRFull_rev_loading_mode;
	4: sw_BR350a_LNWRUkraine_rev_loading_mode;
	default: sw_BR350a_LM_rev_loading_mode;
}
switch(FEAT_TRAINS, SELF, sw_BR350_1b_rev, [STORE_TEMP(position_in_consist_from_end-position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: sw_BR350b_LM_rev_loading_mode;          1: sw_BR350b_SLinkCentral_rev_loading_mode;
	2: sw_BR350b_LNWRSimple_rev_loading_mode;  3: sw_BR350b_LNWRFull_rev_loading_mode;
	4: sw_BR350b_LNWRUkraine_rev_loading_mode;
	default: sw_BR350b_LM_rev_loading_mode;
}
switch(FEAT_TRAINS, SELF, sw_BR350_1c_rev, [STORE_TEMP(position_in_consist_from_end-position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: sw_BR350c_LM_rev_loading_mode;          1: sw_BR350c_SLinkCentral_rev_loading_mode;
	2: sw_BR350c_LNWRSimple_rev_loading_mode;  3: sw_BR350c_LNWRFull_rev_loading_mode;
	4: sw_BR350c_LNWRUkraine_rev_loading_mode;
	default: sw_BR350c_LM_rev_loading_mode;
}
switch(FEAT_TRAINS, SELF, sw_BR350_1d_rev, [STORE_TEMP(position_in_consist_from_end-position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: sw_BR350d_LM_rev_loading_mode;          1: sw_BR350d_SLinkCentral_rev_loading_mode;
	2: sw_BR350d_LNWRSimple_rev_loading_mode;  3: sw_BR350d_LNWRFull_rev_loading_mode;
	4: sw_BR350d_LNWRUkraine_rev_loading_mode;
	default: sw_BR350d_LM_rev_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR350_1_cargo_subtype_text, cargo_subtype) {
	0: return string(str_LondonMidland);
	1: return string(str_SilverlinkCentral);
	2: return string(str_LNWRSimple);
	3: return string(str_LNWR);
	4: return string(STR_LIVERY, string(str_LNWR), string(str_special_Ukraine));
	return CB_RESULT_NO_TEXT;
}


