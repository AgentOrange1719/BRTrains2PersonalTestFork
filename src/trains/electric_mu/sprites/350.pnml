// ============================================================================
// Class 350 sprite and MW switch definitions
// ============================================================================
//
// HOW THE SPRITE SELECTION CHAIN WORKS
// -------------------------------------
// The entry point is sw_BR350_X_direction (called from graphics.default in
// 350.pnml). It reads vehicle_is_reversed in PARENT scope and branches:
//
//   FORWARD path:
//     sw_BR350_X_direction
//       -> sw_BR350_X_fwd_role    [SELF: position_in_articulated_veh % 4]
//         -> sw_BR350_Xy          [SELF: cargo_subtype -> forward spriteset]
//
//   REVERSED path:
//     sw_BR350_X_direction
//       -> sw_BR350_rev_mirror_type
//            Stores (position_in_consist_from_end - position_in_consist)
//            into temp register 0x10F, which is the signed offset from this
//            car to the car that occupied the same geographic tile before
//            reversal. Then reads vehicle_type_id from that mirrored car to
//            identify which subclass (and therefore which livery set) belongs
//            at this geographic position.
//         -> sw_BR350_X_rev_role  [SELF: mirrored car's
//                                  position_in_articulated_veh via
//                                  var[0x61, ..., 0x41] % 4]
//              Recovers the role (front/2nd/3rd/rear) that the mirrored car
//              had within its unit.
//           -> sw_BR350_Xy_rev    [SELF: var[0x61, ..., 0xF2] reads
//                                  cargo_subtype from the mirrored car at
//                                  offset 0x10F -> reversed spriteset]
//
// WHY THE MIRROR TRICK IS NEEDED
// --------------------------------
// OpenTTD physically reorders cars on the track when a consist reverses, so
// a car's SELF cargo_subtype would show the wrong livery at each tile after
// reversal. Reading cargo_subtype from the geographically-equivalent forward
// car instead keeps each livery anchored to its original map position.
//
// CAR ROLE MAPPING (position a/b/c/d = articulated index 0/1/2/3)
//   a (0) = front cab
//   b (1) = 2nd car
//   c (2) = 3rd car
//   d (3) = rear cab
//
// SUBCLASS ITEM IDs (used by sw_BR350_rev_mirror_type)
//   774 = Class 350/1
//   775 = Class 350/2
//   776 = Class 350/3 and 350/4
// ============================================================================


// ============================================================================
// SPRITESETS
// Source: gfx/EMU/350_450.png
//
// PNG layout convention:
//   Forward art:        x=0   (template_train32px_old)
//   Reversed cab ends:  x=175 (separate end-specific art for cars a and d)
//   Reversed middles:   x=0   (cars b and c are symmetric; the reversed
//                              template flips them without a separate sprite)
//
// Each livery occupies four rows (one per car), starting at the y offset
// shown. Reversed spritesets are drawn at x=175 (end cars) or x=0 (middles).
// ============================================================================

spriteset(spriteset_BR350_Purchase, "gfx/EMU/350_450.png") { template_purchase(175, 25) }

// London Midland (y=0)
spriteset(spriteset_BR350a_LM,           "gfx/EMU/350_450.png") { template_train32px_old(0, 0) }
spriteset(spriteset_BR350b_LM,           "gfx/EMU/350_450.png") { template_train32px_old(0, 25) }
spriteset(spriteset_BR350c_LM,           "gfx/EMU/350_450.png") { template_train32px_old(0, 50) }
spriteset(spriteset_BR350d_LM,           "gfx/EMU/350_450.png") { template_train32px_old(0, 75) }
spriteset(spriteset_BR350a_LM_rev,       "gfx/EMU/350_450.png") { template_train32px_old_reversed(175, 0) }
spriteset(spriteset_BR350b_LM_rev,       "gfx/EMU/350_450.png") { template_train32px_old_reversed(0, 25) }
spriteset(spriteset_BR350c_LM_rev,       "gfx/EMU/350_450.png") { template_train32px_old_reversed(0, 50) }
spriteset(spriteset_BR350d_LM_rev,       "gfx/EMU/350_450.png") { template_train32px_old_reversed(175, 75) }

// Silverlink Central (y=100)
spriteset(spriteset_BR350a_SLinkCentral,     "gfx/EMU/350_450.png") { template_train32px_old(0, 100) }
spriteset(spriteset_BR350b_SLinkCentral,     "gfx/EMU/350_450.png") { template_train32px_old(0, 125) }
spriteset(spriteset_BR350c_SLinkCentral,     "gfx/EMU/350_450.png") { template_train32px_old(0, 150) }
spriteset(spriteset_BR350d_SLinkCentral,     "gfx/EMU/350_450.png") { template_train32px_old(0, 175) }
spriteset(spriteset_BR350a_SLinkCentral_rev, "gfx/EMU/350_450.png") { template_train32px_old_reversed(175, 100) }
spriteset(spriteset_BR350b_SLinkCentral_rev, "gfx/EMU/350_450.png") { template_train32px_old_reversed(0, 125) }
spriteset(spriteset_BR350c_SLinkCentral_rev, "gfx/EMU/350_450.png") { template_train32px_old_reversed(0, 150) }
spriteset(spriteset_BR350d_SLinkCentral_rev, "gfx/EMU/350_450.png") { template_train32px_old_reversed(175, 175) }

// TransPennine Express (y=200) — 350/3+4 only
spriteset(spriteset_BR350a_TPE,          "gfx/EMU/350_450.png") { template_train32px_old(0, 200) }
spriteset(spriteset_BR350b_TPE,          "gfx/EMU/350_450.png") { template_train32px_old(0, 225) }
spriteset(spriteset_BR350c_TPE,          "gfx/EMU/350_450.png") { template_train32px_old(0, 250) }
spriteset(spriteset_BR350d_TPE,          "gfx/EMU/350_450.png") { template_train32px_old(0, 275) }
spriteset(spriteset_BR350a_TPE_rev,      "gfx/EMU/350_450.png") { template_train32px_old_reversed(175, 200) }
spriteset(spriteset_BR350b_TPE_rev,      "gfx/EMU/350_450.png") { template_train32px_old_reversed(0, 225) }
spriteset(spriteset_BR350c_TPE_rev,      "gfx/EMU/350_450.png") { template_train32px_old_reversed(0, 250) }
spriteset(spriteset_BR350d_TPE_rev,      "gfx/EMU/350_450.png") { template_train32px_old_reversed(175, 275) }

// LNWR Transitional (y=300) — 350/1 and 350/2 only
spriteset(spriteset_BR350a_LNWRSimple,       "gfx/EMU/350_450.png") { template_train32px_old(0, 300) }
spriteset(spriteset_BR350b_LNWRSimple,       "gfx/EMU/350_450.png") { template_train32px_old(0, 325) }
spriteset(spriteset_BR350c_LNWRSimple,       "gfx/EMU/350_450.png") { template_train32px_old(0, 350) }
spriteset(spriteset_BR350d_LNWRSimple,       "gfx/EMU/350_450.png") { template_train32px_old(0, 375) }
spriteset(spriteset_BR350a_LNWRSimple_rev,   "gfx/EMU/350_450.png") { template_train32px_old_reversed(175, 300) }
