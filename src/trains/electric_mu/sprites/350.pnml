switch(FEAT_TRAINS, SELF, sw_BR350_34_cargo_subtype_text, cargo_subtype) {
	0: return string(str_LondonMidland);
	1: return string(str_TPE);
	2: return string(str_LNWR);
	return CB_RESULT_NO_TEXT;
}


// ============================================================================
// MW / REVERSING ENTRY POINTS  (shared by all three subclasses)
//
// Call chain recap (read bottom-up, since NML requires forward-declaration):
//   Direction gate -> mirror type -> rev role -> rev livery -> spriteset
//                  -> fwd role   -> fwd livery -> spriteset
// ============================================================================

// FORWARD role dispatch: maps articulated index to the livery switch for
// each car position (a=front cab, b=2nd, c=3rd, d=rear cab).
switch(FEAT_TRAINS, SELF, sw_BR350_1_fwd_role, position_in_articulated_veh % 4) {
	0: sw_BR350_1a; 1: sw_BR350_1b; 2: sw_BR350_1c; 3: sw_BR350_1d;
}
switch(FEAT_TRAINS, SELF, sw_BR350_2_fwd_role, position_in_articulated_veh % 4) {
	0: sw_BR350_2a; 1: sw_BR350_2b; 2: sw_BR350_2c; 3: sw_BR350_2d;
}
switch(FEAT_TRAINS, SELF, sw_BR350_34_fwd_role, position_in_articulated_veh % 4) {
	0: sw_BR350_34a; 1: sw_BR350_34b; 2: sw_BR350_34c; 3: sw_BR350_34d;
}

// REVERSED role dispatch: read position_in_articulated_veh (bits 0-7 of var 0x41)
// from the mirrored car (offset already in register 0x10F from sw_BR350_rev_mirror_type).
// This gives the original articulated index of the car that occupied this geographic tile
// before reversal, regardless of where in the consist the 350 unit is positioned.
// Using fe % 4 instead would break when the unit is hauled by an external locomotive,
// because fe is then offset by the number of vehicles ahead of the unit in the consist.
switch(FEAT_TRAINS, SELF, sw_BR350_1_rev_role, var[0x61, 0, 0x000000FF, 0x41] % 4) {
	0: sw_BR350_1a_rev; 1: sw_BR350_1b_rev; 2: sw_BR350_1c_rev; 3: sw_BR350_1d_rev;
	sw_BR350_1d_rev;
}
switch(FEAT_TRAINS, SELF, sw_BR350_2_rev_role, var[0x61, 0, 0x000000FF, 0x41] % 4) {
	0: sw_BR350_2a_rev; 1: sw_BR350_2b_rev; 2: sw_BR350_2c_rev; 3: sw_BR350_2d_rev;
	sw_BR350_2d_rev;
}
switch(FEAT_TRAINS, SELF, sw_BR350_34_rev_role, var[0x61, 0, 0x000000FF, 0x41] % 4) {
	0: sw_BR350_34a_rev; 1: sw_BR350_34b_rev; 2: sw_BR350_34c_rev; 3: sw_BR350_34d_rev;
	sw_BR350_34d_rev;
}

// MIRROR TYPE DISPATCH: computes the signed offset to the car that was at
// this geographic tile before reversal, stores it in temp register 0x10F,
// then reads that car's vehicle_type_id to determine which subclass (and
// therefore which livery set) to apply here. The _rev_role child switches
// inherit 0x10F and use it to read cargo_subtype from the same mirrored car.
switch(FEAT_TRAINS, SELF, sw_BR350_rev_mirror_type,
		[STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F),
		 var[0x61, 0, 0x0000FFFF, 0xC6]]) {
	774: sw_BR350_1_rev_role;
	775: sw_BR350_2_rev_role;
	776: sw_BR350_34_rev_role;
	sw_BR350_1_rev_role; // fallback for any unexpected ID
}

// DIRECTION GATES: entry points called from each item's graphics.default.
// Must be PARENT scope so that vehicle_is_reversed reflects the consist state
// rather than the individual car's state.
switch(FEAT_TRAINS, PARENT, sw_BR350_1_direction, vehicle_is_reversed) {
	1: sw_BR350_rev_mirror_type;
	sw_BR350_1_fwd_role;
}
switch(FEAT_TRAINS, PARENT, sw_BR350_2_direction, vehicle_is_reversed) {
	1: sw_BR350_rev_mirror_type;
	sw_BR350_2_fwd_role;
}
switch(FEAT_TRAINS, PARENT, sw_BR350_34_direction, vehicle_is_reversed) {
