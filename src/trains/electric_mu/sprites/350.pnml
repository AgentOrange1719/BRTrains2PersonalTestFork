spriteset(spriteset_BR350d_LNWRSimple_rev,   "gfx/EMU/350_450.png") { template_train32px_old_reversed(175, 375) }

// LNWR Full (y=400) — 350/1 and 350/3+4 only
spriteset(spriteset_BR350a_LNWRFull,         "gfx/EMU/350_450.png") { template_train32px_old(0, 400) }
spriteset(spriteset_BR350b_LNWRFull,         "gfx/EMU/350_450.png") { template_train32px_old(0, 425) }
spriteset(spriteset_BR350c_LNWRFull,         "gfx/EMU/350_450.png") { template_train32px_old(0, 450) }
spriteset(spriteset_BR350d_LNWRFull,         "gfx/EMU/350_450.png") { template_train32px_old(0, 475) }
spriteset(spriteset_BR350a_LNWRFull_rev,     "gfx/EMU/350_450.png") { template_train32px_old_reversed(175, 400) }
spriteset(spriteset_BR350b_LNWRFull_rev,     "gfx/EMU/350_450.png") { template_train32px_old_reversed(0, 425) }
spriteset(spriteset_BR350c_LNWRFull_rev,     "gfx/EMU/350_450.png") { template_train32px_old_reversed(0, 450) }
spriteset(spriteset_BR350d_LNWRFull_rev,     "gfx/EMU/350_450.png") { template_train32px_old_reversed(175, 475) }

// LNWR Ukraine (y=700) — 350/1 only
spriteset(spriteset_BR350a_LNWRUkraine,      "gfx/EMU/350_450.png") { template_train32px_old(0, 700) }
spriteset(spriteset_BR350b_LNWRUkraine,      "gfx/EMU/350_450.png") { template_train32px_old(0, 725) }
spriteset(spriteset_BR350c_LNWRUkraine,      "gfx/EMU/350_450.png") { template_train32px_old(0, 750) }
spriteset(spriteset_BR350d_LNWRUkraine,      "gfx/EMU/350_450.png") { template_train32px_old(0, 775) }
spriteset(spriteset_BR350a_LNWRUkraine_rev,  "gfx/EMU/350_450.png") { template_train32px_old_reversed(175, 700) }
spriteset(spriteset_BR350b_LNWRUkraine_rev,  "gfx/EMU/350_450.png") { template_train32px_old_reversed(0, 725) }
spriteset(spriteset_BR350c_LNWRUkraine_rev,  "gfx/EMU/350_450.png") { template_train32px_old_reversed(0, 750) }
spriteset(spriteset_BR350d_LNWRUkraine_rev,  "gfx/EMU/350_450.png") { template_train32px_old_reversed(175, 775) }


// ============================================================================
// CLASS 350/1  —  subtype: 0=LM  1=Silverlink  2=LNWR Trans  3=LNWR Full
//                          4=LNWR Ukraine
// ============================================================================

// Forward: cargo_subtype selects the livery spriteset for each car position.
switch(FEAT_TRAINS, SELF, sw_BR350_1a, cargo_subtype) {
	0: spriteset_BR350a_LM;          1: spriteset_BR350a_SLinkCentral;
	2: spriteset_BR350a_LNWRSimple;  3: spriteset_BR350a_LNWRFull;
	4: spriteset_BR350a_LNWRUkraine;
	default: spriteset_BR350a_LM;
}
switch(FEAT_TRAINS, SELF, sw_BR350_1b, cargo_subtype) {
	0: spriteset_BR350b_LM;          1: spriteset_BR350b_SLinkCentral;
	2: spriteset_BR350b_LNWRSimple;  3: spriteset_BR350b_LNWRFull;
	4: spriteset_BR350b_LNWRUkraine;
	default: spriteset_BR350b_LM;
}
switch(FEAT_TRAINS, SELF, sw_BR350_1c, cargo_subtype) {
	0: spriteset_BR350c_LM;          1: spriteset_BR350c_SLinkCentral;
	2: spriteset_BR350c_LNWRSimple;  3: spriteset_BR350c_LNWRFull;
	4: spriteset_BR350c_LNWRUkraine;
	default: spriteset_BR350c_LM;
}
switch(FEAT_TRAINS, SELF, sw_BR350_1d, cargo_subtype) {
	0: spriteset_BR350d_LM;          1: spriteset_BR350d_SLinkCentral;
	2: spriteset_BR350d_LNWRSimple;  3: spriteset_BR350d_LNWRFull;
	4: spriteset_BR350d_LNWRUkraine;
	default: spriteset_BR350d_LM;
}

// Reversed: reads cargo_subtype from the geographically-equivalent forward car.
// Each switch re-stores the same mirror offset into temp register 0x10F before
// reading var[0x61, ..., 0xF2] from the mirrored vehicle.
switch(FEAT_TRAINS, SELF, sw_BR350_1a_rev, [STORE_TEMP(position_in_consist_from_end-position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR350a_LM_rev;          1: spriteset_BR350a_SLinkCentral_rev;
	2: spriteset_BR350a_LNWRSimple_rev;  3: spriteset_BR350a_LNWRFull_rev;
	4: spriteset_BR350a_LNWRUkraine_rev;
	default: spriteset_BR350a_LM_rev;
}
switch(FEAT_TRAINS, SELF, sw_BR350_1b_rev, [STORE_TEMP(position_in_consist_from_end-position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR350b_LM_rev;          1: spriteset_BR350b_SLinkCentral_rev;
	2: spriteset_BR350b_LNWRSimple_rev;  3: spriteset_BR350b_LNWRFull_rev;
	4: spriteset_BR350b_LNWRUkraine_rev;
	default: spriteset_BR350b_LM_rev;
}
switch(FEAT_TRAINS, SELF, sw_BR350_1c_rev, [STORE_TEMP(position_in_consist_from_end-position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR350c_LM_rev;          1: spriteset_BR350c_SLinkCentral_rev;
	2: spriteset_BR350c_LNWRSimple_rev;  3: spriteset_BR350c_LNWRFull_rev;
	4: spriteset_BR350c_LNWRUkraine_rev;
	default: spriteset_BR350c_LM_rev;
}
switch(FEAT_TRAINS, SELF, sw_BR350_1d_rev, [STORE_TEMP(position_in_consist_from_end-position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR350d_LM_rev;          1: spriteset_BR350d_SLinkCentral_rev;
	2: spriteset_BR350d_LNWRSimple_rev;  3: spriteset_BR350d_LNWRFull_rev;
	4: spriteset_BR350d_LNWRUkraine_rev;
	default: spriteset_BR350d_LM_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR350_1_cargo_subtype_text, cargo_subtype) {
	0: return string(str_LondonMidland);
	1: return string(str_SilverlinkCentral);
	2: return string(str_LNWRSimple);
	3: return string(str_LNWR);
	4: return string(STR_LIVERY, string(str_LNWR), string(str_special_Ukraine));
	return CB_RESULT_NO_TEXT;
}


