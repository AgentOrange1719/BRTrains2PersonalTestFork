// Class 444 livery switches
// --------------------
switch(FEAT_TRAINS, SELF, sw_BR444_a, cargo_subtype) {
	0: sw_BR444_a_SWT_loading_mode;
	1: sw_BR444_a_SWR_loading_mode;
	2: sw_BR444_a_SWRPride_loading_mode;
	default: sw_BR444_a_SWT_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR444_b, cargo_subtype) {
	0: sw_BR444_b_SWT_loading_mode;
	1: sw_BR444_b_SWR_loading_mode;
	2: sw_BR444_b_SWRPride_loading_mode;
	default: sw_BR444_b_SWT_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR444_c, cargo_subtype) {
	0: sw_BR444_c_SWT_loading_mode;
	1: sw_BR444_c_SWR_loading_mode;
	2: sw_BR444_c_SWRPride_loading_mode;
	default: sw_BR444_c_SWT_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR444_a_rev_mirror_subtype, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: sw_BR444_a_SWT_reversed_loading_mode;
	1: sw_BR444_a_SWR_reversed_loading_mode;
	2: sw_BR444_a_SWRPride_reversed_loading_mode;
	default: sw_BR444_a_SWT_reversed_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR444_b_rev_mirror_subtype, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: sw_BR444_b_SWT_reversed_loading_mode;
	1: sw_BR444_b_SWR_reversed_loading_mode;
	2: sw_BR444_b_SWRPride_reversed_loading_mode;
	default: sw_BR444_b_SWT_reversed_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR444_c_rev_mirror_subtype, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: sw_BR444_c_SWT_reversed_loading_mode;
	1: sw_BR444_c_SWR_reversed_loading_mode;
	2: sw_BR444_c_SWRPride_reversed_loading_mode;
	default: sw_BR444_c_SWT_reversed_loading_mode;
}

// --------------------
// Class 450 livery switches
// --------------------
switch(FEAT_TRAINS, SELF, sw_BR450_a, cargo_subtype) {
	0: sw_BR450_a_SWT_loading_mode;
	1: sw_BR450_a_SWR_loading_mode;
	2: sw_BR450_a_SWT_loading_mode;
	default: sw_BR450_a_SWT_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR450_b, cargo_subtype) {
	0: sw_BR450_b_SWT_loading_mode;
	1: sw_BR450_b_SWR_loading_mode;
	2: sw_BR450_b_SWT_loading_mode;
	default: sw_BR450_b_SWT_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR450_c, cargo_subtype) {
	0: sw_BR450_c_SWT_loading_mode;
	1: sw_BR450_c_SWR_loading_mode;
	2: sw_BR450_c_SWT_loading_mode;
	default: sw_BR450_c_SWT_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR450_d, cargo_subtype) {
	0: sw_BR450_d_SWT_loading_mode;
	1: sw_BR450_d_SWR_loading_mode;
	2: sw_BR450_d_SWT_loading_mode;
	default: sw_BR450_d_SWT_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR450_a_rev_mirror_subtype, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: sw_BR450_a_SWT_reversed_loading_mode;
	1: sw_BR450_a_SWR_reversed_loading_mode;
	2: sw_BR450_a_SWT_reversed_loading_mode;
	default: sw_BR450_a_SWT_reversed_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR450_b_rev_mirror_subtype, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: sw_BR450_b_SWT_reversed_loading_mode;
	1: sw_BR450_b_SWR_reversed_loading_mode;
	2: sw_BR450_b_SWT_reversed_loading_mode;
	default: sw_BR450_b_SWT_reversed_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR450_c_rev_mirror_subtype, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: sw_BR450_c_SWT_reversed_loading_mode;
	1: sw_BR450_c_SWR_reversed_loading_mode;
	2: sw_BR450_c_SWT_reversed_loading_mode;
	default: sw_BR450_c_SWT_reversed_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR450_d_rev_mirror_subtype, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: sw_BR450_d_SWT_reversed_loading_mode;
	1: sw_BR450_d_SWR_reversed_loading_mode;
	2: sw_BR450_d_SWT_reversed_loading_mode;
	default: sw_BR450_d_SWT_reversed_loading_mode;
}

// --------------------
// Forward role selection from articulated position
// --------------------
switch(FEAT_TRAINS, SELF, sw_BR444_roles_fwd, position_in_articulated_veh % 5) {
	0: sw_BR444_a;
	4: sw_BR444_c;
	sw_BR444_b;
}

switch(FEAT_TRAINS, SELF, sw_BR450_roles_fwd, position_in_articulated_veh % 4) {
	0: sw_BR450_a;
	3: sw_BR450_d;
	sw_BR450_b;
}

// --------------------
// Reversed role selection from mirrored articulated position
// --------------------
switch(FEAT_TRAINS, SELF, sw_BR444_rev_role_5car, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x000000FF, 0x41] % 5]) {
	0: sw_BR444_a_rev_mirror_subtype;
	4: sw_BR444_c_rev_mirror_subtype;
	sw_BR444_b_rev_mirror_subtype;
}

switch(FEAT_TRAINS, SELF, sw_BR450_rev_role_4car, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x000000FF, 0x41] % 4]) {
	0: sw_BR450_a_rev_mirror_subtype;
	3: sw_BR450_d_rev_mirror_subtype;
	sw_BR450_b_rev_mirror_subtype;
}

// Shared reverse-role resolver for mixed 444/450 formations.
switch(FEAT_TRAINS, SELF, sw_BR444_450_rev_from_mirror, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xC6]]) {
	74: sw_BR444_rev_role_5car;
	2074: sw_BR444_rev_role_5car;
	288: sw_BR450_rev_role_4car;
	2288: sw_BR450_rev_role_4car;
	sw_BR444_rev_role_5car;
}

// --------------------
// Push-pull entry points
// --------------------
switch(FEAT_TRAINS, PARENT, sw_BR444_pushpull, vehicle_is_reversed) {
	1: sw_BR444_450_rev_from_mirror;
	sw_BR444_roles_fwd;
}

switch(FEAT_TRAINS, PARENT, sw_BR450_pushpull, vehicle_is_reversed) {
	1: sw_BR444_450_rev_from_mirror;
	sw_BR450_roles_fwd;
}
