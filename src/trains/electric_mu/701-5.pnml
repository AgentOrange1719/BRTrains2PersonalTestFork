// Build fixed 5-car units by returning the same item ID for articulated cars 1..4.
switch(FEAT_TRAINS, SELF, switch_br_701_5_articulated, extra_callback_info1) {
	1..4: return item_br_701_5;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// Third-rail pickup shoes are on cars 1 and 5.
switch(FEAT_TRAINS, SELF, switch_br_701_5_create_effect_pos, position_in_articulated_veh % 5) {
	0: electric_create_visual_effect_SAA3;
	4: electric_create_visual_effect_SAA3;
	return 0;
}

// Translator handling: bit 0 in bitmask_consist_info marks translator wagons.
switch(FEAT_TRAINS, PARENT, switch_br_701_5_power_with_translator, (bitmask_consist_info & 0x01)) {
	0: return 2100;
	return 0;
}

switch(FEAT_TRAINS, PARENT, switch_br_701_5_te_with_translator, (bitmask_consist_info & 0x01)) {
	0: return 76; // 0.30 * 255
	return 0;
}

// Seated total = 274.
switch(FEAT_TRAINS, SELF, switch_br_701_5_capacity_seated, position_in_consist % 5) {
	2: return(54 * param_pax);
	return(55 * param_pax);
}

// Standing-room total = 635.
switch(FEAT_TRAINS, SELF, switch_br_701_5_capacity_high, position_in_consist % 5) {
	return(127 * param_pax);
}

switch(FEAT_TRAINS, SELF, switch_br_701_5_capacity_by_mode, param_standing_capacity) {
	1..2: switch_br_701_5_capacity_high;
	switch_br_701_5_capacity_seated;
}

switch(FEAT_TRAINS, PARENT, switch_br_701_5_capacity_with_translator, (bitmask_consist_info & 0x01)) {
	0: switch_br_701_5_capacity_by_mode;
	return 0;
}

switch(FEAT_TRAINS, SELF, switch_sound_electric_701_5_muted, getbits(extra_callback_info1, 0, 8)) {
	SOUND_EVENT_BREAKDOWN: SOUND_BREAKDOWN_TRAIN_SHIP;
}

switch(FEAT_TRAINS, PARENT, switch_sound_electric_701_5_with_translator, (bitmask_consist_info & 0x01)) {
	0: sw_sound_electric_350;
	switch_sound_electric_701_5_muted;
}

switch(FEAT_TRAINS, PARENT, switch_br_701_5_create_effect_with_translator, (bitmask_consist_info & 0x01)) {
	0: switch_br_701_5_create_effect_pos;
	return 0;
}

switch(FEAT_TRAINS, SELF, switch_br_701_5_start_stop, num_vehs_in_consist) {
	1..11: return CB_RESULT_NO_TEXT;
	return string(STR_BR_701_5_MW_LIMIT);
}

// Allow coupling between both 701 lengths, plus translator wagons.
switch(FEAT_TRAINS, SELF, switch_br_701_5_can_attach_wagon, vehicle_type_id) {
	item_br_701_0: return CB_RESULT_ATTACH_ALLOW;
	item_br_701_5: return CB_RESULT_ATTACH_ALLOW;
	item_BRMk2_Translator: return CB_RESULT_ATTACH_ALLOW;
	return string(STR_CANNOT_ATTACH);
}

switch(FEAT_TRAINS, SELF, switch_br_701_5_additional_text, (param_standing_capacity != 0) * 10 + param_pax) {
	1: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR701_usage),
			string(str_BR701_5_multiple_working),
			string(str_BR701_eos),
			string(str_BR701_5_capacity_1x),
			string(str_BR701_5_liveries)));
	2: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR701_usage),
			string(str_BR701_5_multiple_working),
			string(str_BR701_eos),
			string(str_BR701_5_capacity_2x),
			string(str_BR701_5_liveries)));
	3: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR701_usage),
			string(str_BR701_5_multiple_working),
			string(str_BR701_eos),
			string(str_BR701_5_capacity_3x),
			string(str_BR701_5_liveries)));
	4: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR701_usage),
			string(str_BR701_5_multiple_working),
			string(str_BR701_eos),
			string(str_BR701_5_capacity_4x),
			string(str_BR701_5_liveries)));
	11: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR701_usage),
			string(str_BR701_5_multiple_working),
			string(str_BR701_eos),
			string(str_BR701_5_capacity_hc_1x),
			string(str_BR701_5_liveries)));
	12: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR701_usage),
			string(str_BR701_5_multiple_working),
			string(str_BR701_eos),
			string(str_BR701_5_capacity_hc_2x),
			string(str_BR701_5_liveries)));
	13: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR701_usage),
			string(str_BR701_5_multiple_working),
			string(str_BR701_eos),
			string(str_BR701_5_capacity_hc_3x),
			string(str_BR701_5_liveries)));
	14: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR701_usage),
			string(str_BR701_5_multiple_working),
			string(str_BR701_eos),
			string(str_BR701_5_capacity_hc_4x),
			string(str_BR701_5_liveries)));
	return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_emu),
			string(str_BR701_usage),
			string(str_BR701_5_multiple_working),
			string(str_BR701_eos),
			string(str_BR701_5_capacity_1x),
			string(str_BR701_5_liveries)));
}

item(FEAT_TRAINS, item_br_701_5, 429) {
	property {
		variant_group:                    header_Aventra;
		name: string(STR_BR_701_5);
		climates_available: ALL_CLIMATES; // available in all climates
		introduction_date: date(2020, 11, 01);
		model_life: VEHICLE_NEVER_EXPIRES; // keep available forever
		vehicle_life: 30; // years after vehicle is deemed "old" and should be replaced
		reliability_decay: 0; // dont reduce reliabilty, (will grow from 75% upwards over the years)
		refittable_cargo_classes: bitmask(CC_PASSENGERS);
		non_refittable_cargo_classes: bitmask();
		cost_factor: 95;
		loading_speed: 25;
		running_cost_factor: 55;
		cargo_allow_refit: [];
		cargo_disallow_refit: [];
		speed: 100 mph;
		power: 2100 hp;
		cargo_capacity: 55;
		weight: 120 ton;
		sprite_id: SPRITE_ID_NEW_TRAIN; // required
		refit_cost: 0;
		track_type: THIRD;
		ai_special_flag: AI_FLAG_PASSENGER; // tell ai that this is a passenger train
		running_cost_base: RUNNING_COST_ELECTRIC;
		misc_flags: TRAIN_FLAG_MU;
		dual_headed: 0; // set to 0 otherwise limited to 2 cars only
		engine_class: ENGINE_CLASS_ELECTRIC; // even if its 3rd rail, ELECTRIC would give overhead wire effects
		extra_power_per_wagon: 0 kW;
		tractive_effort_coefficient: 0.3;
		air_drag_coefficient: 0.06;
		length: 8; // full tile length vehicle
		effect_spawn_model_and_powered: EFFECT_SPAWN_MODEL_ELECTRIC; // visual fx
		extra_weight_per_wagon: 0 ton;
		bitmask_vehicle_info: 0;
	}

	graphics {
		default: switch_br_701_5_direction;
		purchase: spriteset_br_701_purchase;
		articulated_part: switch_br_701_5_articulated;
		start_stop: switch_br_701_5_start_stop;
		can_attach_wagon: switch_br_701_5_can_attach_wagon;
		create_effect: switch_br_701_5_create_effect_with_translator;
		additional_text: switch_br_701_5_additional_text;
		sound_effect: switch_sound_electric_701_5_with_translator;
		power: switch_br_701_5_power_with_translator;
		tractive_effort_coefficient: switch_br_701_5_te_with_translator;
		cargo_capacity: switch_br_701_5_capacity_with_translator;
		cost_factor: return(GetAdjustedCost(95));
		running_cost_factor: return(GetAdjustedCost(55));
	}
}
