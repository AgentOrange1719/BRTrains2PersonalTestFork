switch(FEAT_TRAINS, SELF, sw_BR380_4car_articulated, extra_callback_info1) {
	1..3: return item_BR380_4car;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, sw_BR380_4car_visual_effect_fwd, position_in_articulated_veh % 4) {
	2: visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 2, DISABLE_WAGON_POWER);
	visual_effect_and_powered(VISUAL_EFFECT_DISABLE, 0, DISABLE_WAGON_POWER);
}

switch(FEAT_TRAINS, SELF, sw_BR380_4car_visual_effect_rev, position_in_articulated_veh % 4) {
	1: visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 2, DISABLE_WAGON_POWER);
	visual_effect_and_powered(VISUAL_EFFECT_DISABLE, 0, DISABLE_WAGON_POWER);
}

switch(FEAT_TRAINS, PARENT, sw_BR380_4car_visual_effect, vehicle_is_reversed) {
	1: sw_BR380_4car_visual_effect_rev;
	sw_BR380_4car_visual_effect_fwd;
}

switch(FEAT_TRAINS, SELF, sw_BR380_4car_start_stop, num_vehs_in_consist) {
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_TRAINS, SELF, sw_BR380_4car_can_attach_wagon, vehicle_type_id) {
	item_BR380_4car: return CB_RESULT_ATTACH_ALLOW;
	item_BR380_3car: return CB_RESULT_ATTACH_ALLOW;
	return string(STR_CANNOT_ATTACH);
}

switch(FEAT_TRAINS, SELF, sw_BR380_4car_capacity, position_in_articulated_veh % 4) {
	0: return(66 * param_pax);
	1: return(67 * param_pax);
	2: return(66 * param_pax);
	3: return(66 * param_pax);
	return(66 * param_pax);
}

item(FEAT_TRAINS, item_BR380_4car, 768) {
	property {
		variant_group: header_Desiro;
		name: string(STR_NAME_BR380_4car);
		climates_available: ALL_CLIMATES;
		introduction_date: date(2010, 12, 08);
		model_life: VEHICLE_NEVER_EXPIRES;
		vehicle_life: 30;
		reliability_decay: 0;
		refittable_cargo_classes: bitmask(CC_PASSENGERS);
		non_refittable_cargo_classes: bitmask();
		loading_speed: 25;
		cargo_allow_refit: [];
		cargo_disallow_refit: [];

		speed: 100 mph;
		power: 2682 hp;
		cargo_capacity: 66;
		weight: 132 ton;

		sprite_id: SPRITE_ID_NEW_TRAIN;
		refit_cost: 0;
		track_type: ELRL;
		ai_special_flag: AI_FLAG_PASSENGER;
		running_cost_base: RUNNING_COST_ELECTRIC;
		dual_headed: 0;
		engine_class: ENGINE_CLASS_ELECTRIC;
		extra_power_per_wagon: 0 kW;
		tractive_effort_coefficient: 0.3;
		air_drag_coefficient: 0.06;
		length: 8;
		visual_effect_and_powered: visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 2, DISABLE_WAGON_POWER);
		extra_weight_per_wagon: 0 ton;
		bitmask_vehicle_info: 0;
	}

	graphics {
		default: sw_BR380_pushpull;
		purchase: spriteset_BR380_Purchase;
		cargo_subtype_text: sw_BR380_cargo_subtype_text;
		articulated_part: sw_BR380_4car_articulated;
		start_stop: sw_BR380_4car_start_stop;
		can_attach_wagon: sw_BR380_4car_can_attach_wagon;
		visual_effect_and_powered: sw_BR380_4car_visual_effect;
		additional_text: return(string(str_purchase_loco_with_liveries_and_mw, string(str_purchase_type_emu), string(str_BR380_usage), string(str_multiple_working_within_class), string(str_BR380_eos), string(str_BR380_liveries)));
		cargo_capacity: sw_BR380_4car_capacity;
		cost_factor: return(GetAdjustedCost(88));
		running_cost_factor: return(GetAdjustedCost(57));
	}
}
