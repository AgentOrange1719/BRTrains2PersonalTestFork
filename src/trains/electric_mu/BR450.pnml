// Class 450 (4-car)
// Operational formation: A-B-B-D

// Build fixed 4-car units by returning the same item ID for articulated cars 1..3.
switch(FEAT_TRAINS, SELF, sw_articulated_BR450, extra_callback_info1) {
	1..3: return item_BR450;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// Duplicate SWT on subtype 2 so the refit menu has an explicit SWT target.
switch(FEAT_TRAINS, SELF, sw_BR450_cargo_subtype_text, cargo_subtype) {
	0: return string(str_SWT);
	1: return string(str_SWR);
	2: return string(str_SWT);
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_TRAINS, SELF, sw_BR450_cargo_capacity, position_in_articulated_veh % 4) {
	0: return(70 * param_pax);
	3: return(70 * param_pax);
	return(72 * param_pax);
}

// Preserve the legacy behaviour where only the lead car emits pickup effects.
switch(FEAT_TRAINS, SELF, sw_BR450_create_effect, position_in_articulated_veh % 4) {
	0: electric_create_visual_effect_SAA3;
	return 0;
}

// Class 450 can multiple-work with Class 450 and Class 444.
switch(FEAT_TRAINS, SELF, sw_BR450_can_attach_wagon, vehicle_type_id) {
	item_BR450: return CB_RESULT_ATTACH_ALLOW;
	item_BR444: return CB_RESULT_ATTACH_ALLOW;
	return string(STR_CANNOT_ATTACH);
}

item(FEAT_TRAINS, item_BR450, 288) {
	property {
		variant_group: header_Desiro;
		name: string(STR_NAME_BR450);
		climates_available: ALL_CLIMATES;
		introduction_date: date(2002, 4, 21);
		model_life: 15;
		retire_early: 1;
		vehicle_life: 50;
		reliability_decay: 7;
		refittable_cargo_classes: CC_PASSENGERS;
		cargo_allow_refit: [PASS, TOUR];
		loading_speed: 25;
		cost_factor: 42;
		running_cost_factor: 38;
		sprite_id: SPRITE_ID_NEW_TRAIN;
		speed: 100 mph;
		refit_cost: 0;
		track_type: THIRD;
		ai_special_flag: AI_FLAG_CARGO;
		power: 2682 hp;
		running_cost_base: RUNNING_COST_ELECTRIC;
		dual_headed: 0;
		default_cargo_type: PASS;
		cargo_capacity: 70;
		weight: 190 ton;
		engine_class: ENGINE_CLASS_ELECTRIC;
		tractive_effort_coefficient: 0.3;
		air_drag_coefficient: 0.2;
		length: 8;
		effect_spawn_model_and_powered: EFFECT_SPAWN_MODEL_ELECTRIC;
		extra_weight_per_wagon: 0;
		bitmask_vehicle_info: 0;
		cargo_age_period: 185;
	}
	graphics {
		additional_text: return(string(str_purchase_loco_with_liveries_and_mw, string(str_purchase_type_emu), string(str_BR450_usage), string(STR_CONCAT_2, string(str_multiple_working_within_class), string(str_multiple_working_with_class_444)), string(str_BR450_eos), string(str_BR450_liveries)));
		can_attach_wagon: sw_BR450_can_attach_wagon;
		cargo_subtype_text: sw_BR450_cargo_subtype_text;
		articulated_part: sw_articulated_BR450;
		default: sw_BR450_pushpull;
		purchase: spriteset_BR450_Purchase;
		colour_mapping: return PALETTE_CC_FIRST;
		create_effect: sw_BR450_create_effect;
		sound_effect: sw_sound_electric_350;
		cargo_capacity: sw_BR450_cargo_capacity;
		cost_factor: return(GetAdjustedCost(42));
		running_cost_factor: return(GetAdjustedCost(38));
	}
}
