// Class 360 single-ID articulated unit definitions:
// - Class 360/1 (4-car)
// - Class 360/2 (4-car)
// - Class 360/2 (5-car)

switch(FEAT_TRAINS, SELF, sw_articulated_BR360_1, extra_callback_info1) {
	1..3: return item_BR360_1;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, sw_BR360_2_articulated_4car, extra_callback_info1) {
	1..3: return item_BR360_2_4car;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, sw_BR360_2_articulated_5car, extra_callback_info1) {
	1..4: return item_BR360_2_5car;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, sw_BR360_1_cargo_subtype_text, cargo_subtype) {
	0: return string(str_FirstGreatEasternBarbie);
	1: return string(str_NXEABlue);
	2: return string(str_NXEAGrey);
	3: return string(str_EMRBlue);
	4: return string(str_EMRMaroon);
	5: return string(str_EMRMaroonCab);
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_TRAINS, SELF, sw_BR360_2_4car_cargo_subtype_text, cargo_subtype) {
	0: return string(str_HeathrowConnect);
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_TRAINS, SELF, sw_BR360_2_5car_cargo_subtype_text, cargo_subtype) {
	0: return string(str_HeathrowConnect);
	1: return string(str_HeathrowExpressPurple);
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_TRAINS, SELF, sw_BR360_1_capacity, position_in_articulated_veh % 4) {
	return(70 * param_pax);
}

switch(FEAT_TRAINS, SELF, sw_BR360_2_4car_capacity, position_in_articulated_veh % 4) {
	return(70 * param_pax);
}

switch(FEAT_TRAINS, SELF, sw_BR360_2_5car_capacity, position_in_articulated_veh % 5) {
	0: return(67 * param_pax);
	1: return(67 * param_pax);
	2: return(66 * param_pax);
	3: return(66 * param_pax);
	4: return(67 * param_pax);
	return(67 * param_pax);
}

// Preserve legacy behavior where only the lead car emits pickup effects.
switch(FEAT_TRAINS, SELF, sw_BR360_1_create_effect, position_in_articulated_veh % 4) {
	0: electric_create_visual_effect;
	return 0;
}

switch(FEAT_TRAINS, SELF, sw_BR360_2_4car_create_effect, position_in_articulated_veh % 4) {
	0: electric_create_visual_effect;
	return 0;
}

switch(FEAT_TRAINS, SELF, sw_BR360_2_5car_create_effect, position_in_articulated_veh % 5) {
	0: electric_create_visual_effect;
	return 0;
}

item(FEAT_TRAINS, item_BR360_1, 737) {
	property {
		variant_group: header_Desiro;
		name: string(STR_NAME_BR360_1);
		climates_available: ALL_CLIMATES;
		introduction_date: date(2002, 4, 1);
		model_life: 15;
		retire_early: 1;
		vehicle_life: 50;
		reliability_decay: 7;
		refittable_cargo_classes: CC_PASSENGERS;
		cargo_allow_refit: [PASS, TOUR];
		loading_speed: 25;
		cost_factor: 42;
		running_cost_factor: 38;
		sprite_id: SPRITE_ID_NEW_TRAIN;
		speed: 110 mph;
		refit_cost: 0;
		track_type: ELRL;
		ai_special_flag: AI_FLAG_CARGO;
		power: 2080 hp;
		running_cost_base: RUNNING_COST_ELECTRIC;
		dual_headed: 0;
		default_cargo_type: PASS;
		cargo_capacity: 70;
		weight: 165 ton;
		engine_class: ENGINE_CLASS_ELECTRIC;
		tractive_effort_coefficient: 0.3;
		air_drag_coefficient: 0.2;
		length: 8;
		effect_spawn_model_and_powered: EFFECT_SPAWN_MODEL_ELECTRIC;
		extra_weight_per_wagon: 0;
		bitmask_vehicle_info: 0;
		cargo_age_period: 185;
	}
	graphics {
		additional_text: return(string(str_purchase_loco_with_liveries_and_mw, string(str_purchase_type_emu), string(str_BR360_usage), string(str_multiple_working_within_subclass), string(str_BR360_eos), string(str_BR360_1_liveries)));
		can_attach_wagon: sw_BR360_1_can_attach_wagon;
		cargo_subtype_text: sw_BR360_1_cargo_subtype_text;
		articulated_part: sw_articulated_BR360_1;
		default: sw_BR360_1_pushpull;
		purchase: spriteset_BR360_1_Purchase;
		colour_mapping: return PALETTE_CC_FIRST;
		create_effect: sw_BR360_1_create_effect;
		sound_effect: sw_sound_electric_350;
		cargo_capacity: sw_BR360_1_capacity;
		cost_factor: return(GetAdjustedCost(42));
		running_cost_factor: return(GetAdjustedCost(38));
	}
}

