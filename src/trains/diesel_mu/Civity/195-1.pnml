// Define articulations
switch(FEAT_TRAINS, SELF, switch_br_195_1_articulated, extra_callback_info1) {
	1..2: return item_br_195_1;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// Only give particle effects to front/rear cars
switch(FEAT_TRAINS, SELF, switch_br_195_1_particles, position_in_articulated_veh % 3) {
	0: visual_effect_and_powered(VISUAL_EFFECT_DIESEL, 2, DISABLE_WAGON_POWER);
	2: visual_effect_and_powered(VISUAL_EFFECT_DIESEL, 2, DISABLE_WAGON_POWER);
	visual_effect_and_powered(VISUAL_EFFECT_DISABLE, 0, DISABLE_WAGON_POWER);
}

// Start/stop switch, used to limit maximum length
switch(FEAT_TRAINS, SELF, switch_br_195_1_start_stop, num_vehs_in_consist) {
	return CB_RESULT_NO_TEXT;
}

// Only allow the same train type to be added to itself
switch(FEAT_TRAINS, SELF, switch_br_195_1_can_attach_wagon, vehicle_type_id) {
	item_br_195_1: return CB_RESULT_ATTACH_ALLOW;
	item_br_195_0: return CB_RESULT_ATTACH_ALLOW;
	item_BRMk2_Translator: return CB_RESULT_ATTACH_ALLOW;
	return string(STR_CANNOT_ATTACH);
}

switch(FEAT_TRAINS, PARENT, switch_br_195_1_power_with_translator, (bitmask_consist_info & 0x01)) {
	0: return 1569;
	return 0;
}

switch(FEAT_TRAINS, PARENT, switch_br_195_1_te_with_translator, (bitmask_consist_info & 0x01)) {
	0: return 76; // 0.30 * 255
	return 0;
}

switch(FEAT_TRAINS, SELF, switch_br_195_1_capacity_seated, position_in_articulated_veh % 3) {
	return(68 * param_pax);
}

switch(FEAT_TRAINS, SELF, switch_br_195_1_capacity_high, position_in_articulated_veh % 3) {
	return(115 * param_pax);
}

switch(FEAT_TRAINS, SELF, switch_br_195_1_capacity_by_mode, param_standing_capacity) {
	2: switch_br_195_1_capacity_high;
	switch_br_195_1_capacity_seated;
}

switch(FEAT_TRAINS, PARENT, switch_br_195_1_capacity_with_translator, (bitmask_consist_info & 0x01)) {
	0: switch_br_195_1_capacity_by_mode;
	return 0;
}

switch(FEAT_TRAINS, PARENT, switch_br_195_1_particles_with_translator, (bitmask_consist_info & 0x01)) {
	0: switch_br_195_1_particles;
	visual_effect_and_powered(VISUAL_EFFECT_DISABLE, 0, DISABLE_WAGON_POWER);
}

switch(FEAT_TRAINS, SELF, switch_br_195_1_additional_text, (param_standing_capacity == 2) * 10 + param_pax) {
	1: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_dmu),
			string(str_BR195_usage),
			string(str_multiple_working_within_class),
			string(str_BR195_eos),
			string(str_BR195_1_capacity_1x),
			string(str_BR195_liveries)));
	2: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_dmu),
			string(str_BR195_usage),
			string(str_multiple_working_within_class),
			string(str_BR195_eos),
			string(str_BR195_1_capacity_2x),
			string(str_BR195_liveries)));
	3: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_dmu),
			string(str_BR195_usage),
			string(str_multiple_working_within_class),
			string(str_BR195_eos),
			string(str_BR195_1_capacity_3x),
			string(str_BR195_liveries)));
	4: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_dmu),
			string(str_BR195_usage),
			string(str_multiple_working_within_class),
			string(str_BR195_eos),
			string(str_BR195_1_capacity_4x),
			string(str_BR195_liveries)));
	11: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_dmu),
			string(str_BR195_usage),
			string(str_multiple_working_within_class),
			string(str_BR195_eos),
			string(str_BR195_1_capacity_hc_1x),
			string(str_BR195_liveries)));
	12: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_dmu),
			string(str_BR195_usage),
			string(str_multiple_working_within_class),
			string(str_BR195_eos),
			string(str_BR195_1_capacity_hc_2x),
			string(str_BR195_liveries)));
	13: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_dmu),
			string(str_BR195_usage),
			string(str_multiple_working_within_class),
			string(str_BR195_eos),
			string(str_BR195_1_capacity_hc_3x),
			string(str_BR195_liveries)));
	14: return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_dmu),
			string(str_BR195_usage),
			string(str_multiple_working_within_class),
			string(str_BR195_eos),
			string(str_BR195_1_capacity_hc_4x),
			string(str_BR195_liveries)));
	return(string(str_purchase_loco_with_liveries_and_capacity_and_mw,
			string(str_purchase_type_dmu),
			string(str_BR195_usage),
			string(str_multiple_working_within_class),
			string(str_BR195_eos),
			string(str_BR195_1_capacity_1x),
			string(str_BR195_liveries)));
}

// Class 195/1 (3car)
item(FEAT_TRAINS, item_br_195_1, 431) {
	property {
		variant_group:					header_Civity;
		name: string(STR_BR_195_3CAR);
		climates_available: ALL_CLIMATES;
		introduction_date: date(2019, 07, 01);
		model_life: VEHICLE_NEVER_EXPIRES;
		vehicle_life: 35;
		reliability_decay: 0;
		refittable_cargo_classes: bitmask(CC_PASSENGERS);
		non_refittable_cargo_classes: bitmask();
		cost_factor: 60;
		loading_speed: 25;
		running_cost_factor: 33;
		cargo_allow_refit: [];
		cargo_disallow_refit: [];

		speed: 100 mph;
		power: 1569 hp;
		cargo_capacity: 68;
		weight: 128.36 ton;

		sprite_id: SPRITE_ID_NEW_TRAIN;
		refit_cost: 0;
		track_type: RAIL;
		ai_special_flag: AI_FLAG_PASSENGER;
		running_cost_base: RUNNING_COST_DIESEL;
		dual_headed: 0;
		engine_class: ENGINE_CLASS_DIESEL;
		extra_power_per_wagon: 0 kW;
		tractive_effort_coefficient: 0.3;
		air_drag_coefficient: 0.06;
		length: 8;
		visual_effect_and_powered: visual_effect_and_powered(VISUAL_EFFECT_DIESEL, 2, DISABLE_WAGON_POWER);
		extra_weight_per_wagon: 0 ton;
		bitmask_vehicle_info: 0;
	}

	graphics {
		default: sw_BR195_1_direction;
		purchase: spriteset_br_195_purchase;

		articulated_part: switch_br_195_1_articulated;
		start_stop: switch_br_195_1_start_stop;
		can_attach_wagon: switch_br_195_1_can_attach_wagon;
		visual_effect_and_powered: switch_br_195_1_particles_with_translator;
		power: switch_br_195_1_power_with_translator;
		tractive_effort_coefficient: switch_br_195_1_te_with_translator;
		cargo_capacity: switch_br_195_1_capacity_with_translator;
		additional_text: switch_br_195_1_additional_text;
		cost_factor: return(GetAdjustedCost(60));
		running_cost_factor: return(GetAdjustedCost(33));
	}
}
