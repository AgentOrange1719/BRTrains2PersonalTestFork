// Class 221 (5-car)
// Formation: A-B-B-B-C

switch(FEAT_TRAINS, SELF, switch_articulated_BR221, extra_callback_info1) {
	1..4: return item_BR221;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, sw_BR221_capacity_middle_by_subtype, cargo_subtype) {
	0: return(54 * param_pax);
	return(70 * param_pax);
}

switch(FEAT_TRAINS, SELF, sw_BR221_capacity, position_in_articulated_veh % 5) {
	0: return(42 * param_pax);
	3: sw_BR221_capacity_middle_by_subtype;
	4: return(26 * param_pax);
	return(70 * param_pax);
}

switch(FEAT_TRAINS, SELF, switch_BR221_can_attach_wagon, vehicle_type_id) {
	item_BR221: return CB_RESULT_ATTACH_ALLOW;
	item_BR221_4: return CB_RESULT_ATTACH_ALLOW;
	item_BR220: return CB_RESULT_ATTACH_ALLOW;
	return string(STR_CANNOT_ATTACH);
}
switch(FEAT_TRAINS, SELF, switch_BR221_sound_muted, getbits(extra_callback_info1, 0, 8)) {
	SOUND_EVENT_BREAKDOWN: SOUND_BREAKDOWN_TRAIN_SHIP;
}
item(FEAT_TRAINS, item_BR221, 188) {
	property {
		variant_group:					header_Voyager;
		name: 							string(STR_NAME_BR221);
		climates_available: 			ALL_CLIMATES;
		introduction_date:				date(2001,4,21);
		model_life:						8;
		retire_early:					1;
		vehicle_life:					50;
		reliability_decay:				7;
		refittable_cargo_classes:		CC_PASSENGERS;
		cargo_allow_refit:				[PASS, TOUR];
		loading_speed:					20;
		cost_factor:					92;
		running_cost_factor:			72;
		sprite_id:						SPRITE_ID_NEW_TRAIN;
		speed:							125 mph;
		curve_speed_mod:				0.2;
		refit_cost:						0;
		track_type:						RAIL;
		ai_special_flag:				AI_FLAG_CARGO;
		power:							3000 hp;
		running_cost_base:				RUNNING_COST_DIESEL;
		dual_headed:					0;
		default_cargo_type:				PASS;
		cargo_capacity:					42;
		weight:							283 ton;
		engine_class:					ENGINE_CLASS_DIESEL;
		tractive_effort_coefficient:	0.3;
		air_drag_coefficient:			0.1;
		length:							8;
		effect_spawn_model_and_powered:	EFFECT_SPAWN_MODEL_DIESEL;
		extra_weight_per_wagon:			0;
		bitmask_vehicle_info:			0;
		cargo_age_period:				185;
	}
	graphics {
		additional_text:				return(string(str_purchase_loco_with_liveries_and_mw,string(str_purchase_type_demu),string(str_BR221_usage),string(STR_CONCAT_2, string(str_multiple_working_within_class), string(str_multiple_working_with_class_220)),string(str_BR221_eos),string(str_BR221_liveries)));
		can_attach_wagon:				switch_BR221_can_attach_wagon;
		cargo_subtype_text:				sw_BR221_cargo_subtype_text;
		articulated_part:				switch_articulated_BR221;
		default: 						sw_BR221_pushpull;
		purchase:						spriteset_BR221_Purchase;
		colour_mapping: 				return PALETTE_CC_FIRST;
		create_effect:					diesel_create_visual_effect;
		sound_effect:					sw_sound_diesel_220;
		power:							return 3000;
		tractive_effort_coefficient:	return 76;
		cargo_capacity:					sw_BR221_capacity;
		cost_factor:					return(GetAdjustedCost(92));
		running_cost_factor: 			return(GetAdjustedCost(72));
	}
}
