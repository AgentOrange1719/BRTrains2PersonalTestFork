	spriteset_br_331_middle_panto_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR331_rev_role_4car, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x000000FF, 0x41] % 4]) {
	0: spriteset_br_195_331_front_rev;
	1: spriteset_br_331_middle_panto_rev;
	2: spriteset_br_195_331_middle_rev;
	3: spriteset_br_195_331_rear_rev;
	spriteset_br_195_331_middle_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR331_rev_from_mirror, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xC6]]) {
	424: sw_BR331_rev_role_3car;
	2424: sw_BR331_rev_role_3car;
	425: sw_BR331_rev_role_4car;
	2425: sw_BR331_rev_role_4car;
	sw_BR331_rev_role_3car;
}

