	1: sw_BR331_rev_from_mirror;
	sw_BR331_roles_fwd_3car;
}

switch(FEAT_TRAINS, PARENT, sw_BR331_1_direction, vehicle_is_reversed) {
	1: sw_BR331_rev_from_mirror;
	sw_BR331_roles_fwd_4car;
