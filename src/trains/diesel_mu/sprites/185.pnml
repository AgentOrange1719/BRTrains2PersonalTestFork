// Class 185 sprite groups and multiple-working helpers.

spriteset(spriteset_BR185_Purchase, "gfx/DMU/185.png") { template_purchase(400, 0) }

// Spritegroup definitions. Grouped by livery, with reversed sprites for multiple working.
// Only cab cars use reversed sprites. Middle car points to existing sprite, as reversed template is enough. If a livery is updated/redrawn to be asymetric, change reversed 185b sprite definitions accordingly.
// First Dynamic livery sprites (A/B/C plus reversed).
spriteset(spriteset_BR185a_FirstDynamic, "gfx/DMU/185.png") { template_train32px_old(0, 0) }
spriteset(spriteset_BR185a_FirstDynamic_loading, "gfx/DMU/185.png") { template_train32px_old(200, 0) }
spriteset(spriteset_BR185b_FirstDynamic, "gfx/DMU/185.png") { template_train32px_old(0, 50) }
spriteset(spriteset_BR185b_FirstDynamic_loading, "gfx/DMU/185.png") { template_train32px_old(200, 50) }
spriteset(spriteset_BR185c_FirstDynamic, "gfx/DMU/185.png") { template_train32px_old(0, 75) }
spriteset(spriteset_BR185c_FirstDynamic_loading, "gfx/DMU/185.png") { template_train32px_old(200, 75) }
spriteset(spriteset_BR185a_FirstDynamic_rev, "gfx/DMU/185.png") { template_train32px_old_reversed(0, 25) }
spriteset(spriteset_BR185a_FirstDynamic_rev_loading, "gfx/DMU/185.png") { template_train32px_old_reversed(200, 25) }
spriteset(spriteset_BR185b_FirstDynamic_rev, "gfx/DMU/185.png") { template_train32px_old_reversed(0, 50) }
spriteset(spriteset_BR185b_FirstDynamic_rev_loading, "gfx/DMU/185.png") { template_train32px_old_reversed(200, 50) }
spriteset(spriteset_BR185c_FirstDynamic_rev, "gfx/DMU/185.png") { template_train32px_old_reversed(0, 100) }
spriteset(spriteset_BR185c_FirstDynamic_rev_loading, "gfx/DMU/185.png") { template_train32px_old_reversed(200, 100) }

// First Group livery sprites (A/B/C plus reversed).
spriteset(spriteset_BR185a_FirstGroup, "gfx/DMU/185.png") { template_train32px_old(0, 125) }
spriteset(spriteset_BR185a_FirstGroup_loading, "gfx/DMU/185.png") { template_train32px_old(200, 125) }
spriteset(spriteset_BR185b_FirstGroup, "gfx/DMU/185.png") { template_train32px_old(0, 175) }
spriteset(spriteset_BR185b_FirstGroup_loading, "gfx/DMU/185.png") { template_train32px_old(200, 175) }
spriteset(spriteset_BR185c_FirstGroup, "gfx/DMU/185.png") { template_train32px_old(0, 200) }
spriteset(spriteset_BR185c_FirstGroup_loading, "gfx/DMU/185.png") { template_train32px_old(200, 200) }
spriteset(spriteset_BR185a_FirstGroup_rev, "gfx/DMU/185.png") { template_train32px_old_reversed(0, 150) }
spriteset(spriteset_BR185a_FirstGroup_rev_loading, "gfx/DMU/185.png") { template_train32px_old_reversed(200, 150) }
spriteset(spriteset_BR185b_FirstGroup_rev, "gfx/DMU/185.png") { template_train32px_old_reversed(0, 175) }
spriteset(spriteset_BR185b_FirstGroup_rev_loading, "gfx/DMU/185.png") { template_train32px_old_reversed(200, 175) }
spriteset(spriteset_BR185c_FirstGroup_rev, "gfx/DMU/185.png") { template_train32px_old_reversed(0, 225) }
spriteset(spriteset_BR185c_FirstGroup_rev_loading, "gfx/DMU/185.png") { template_train32px_old_reversed(200, 225) }

// First TPE Geometric livery sprites (A/B/C plus reversed).
spriteset(spriteset_BR185a_FirstTPEGeometric, "gfx/DMU/185.png") { template_train32px_old(0, 250) }
spriteset(spriteset_BR185a_FirstTPEGeometric_loading, "gfx/DMU/185.png") { template_train32px_old(200, 250) }
spriteset(spriteset_BR185b_FirstTPEGeometric, "gfx/DMU/185.png") { template_train32px_old(0, 300) }
spriteset(spriteset_BR185b_FirstTPEGeometric_loading, "gfx/DMU/185.png") { template_train32px_old(200, 300) }
spriteset(spriteset_BR185c_FirstTPEGeometric, "gfx/DMU/185.png") { template_train32px_old(0, 325) }
spriteset(spriteset_BR185c_FirstTPEGeometric_loading, "gfx/DMU/185.png") { template_train32px_old(200, 325) }
spriteset(spriteset_BR185a_FirstTPEGeometric_rev, "gfx/DMU/185.png") { template_train32px_old_reversed(0, 275) }
spriteset(spriteset_BR185a_FirstTPEGeometric_rev_loading, "gfx/DMU/185.png") { template_train32px_old_reversed(200, 275) }
spriteset(spriteset_BR185b_FirstTPEGeometric_rev, "gfx/DMU/185.png") { template_train32px_old_reversed(0, 300) }
spriteset(spriteset_BR185b_FirstTPEGeometric_rev_loading, "gfx/DMU/185.png") { template_train32px_old_reversed(200, 300) }
spriteset(spriteset_BR185c_FirstTPEGeometric_rev, "gfx/DMU/185.png") { template_train32px_old_reversed(0, 350) }
spriteset(spriteset_BR185c_FirstTPEGeometric_rev_loading, "gfx/DMU/185.png") { template_train32px_old_reversed(200, 350) }

// Loading spritegroups and parameter gates.
spritegroup spritegroup_BR185a_FirstDynamic {
	loading: spriteset_BR185a_FirstDynamic_loading;
	loaded: spriteset_BR185a_FirstDynamic;
}
spritegroup spritegroup_BR185b_FirstDynamic {
	loading: spriteset_BR185b_FirstDynamic_loading;
	loaded: spriteset_BR185b_FirstDynamic;
}
spritegroup spritegroup_BR185c_FirstDynamic {
	loading: spriteset_BR185c_FirstDynamic_loading;
	loaded: spriteset_BR185c_FirstDynamic;
}
spritegroup spritegroup_BR185a_FirstDynamic_rev {
	loading: spriteset_BR185a_FirstDynamic_rev_loading;
	loaded: spriteset_BR185a_FirstDynamic_rev;
}
spritegroup spritegroup_BR185b_FirstDynamic_rev {
	loading: spriteset_BR185b_FirstDynamic_rev_loading;
	loaded: spriteset_BR185b_FirstDynamic_rev;
}
spritegroup spritegroup_BR185c_FirstDynamic_rev {
	loading: spriteset_BR185c_FirstDynamic_rev_loading;
	loaded: spriteset_BR185c_FirstDynamic_rev;
}

spritegroup spritegroup_BR185a_FirstGroup {
	loading: spriteset_BR185a_FirstGroup_loading;
	loaded: spriteset_BR185a_FirstGroup;
}
spritegroup spritegroup_BR185b_FirstGroup {
	loading: spriteset_BR185b_FirstGroup_loading;
	loaded: spriteset_BR185b_FirstGroup;
}
spritegroup spritegroup_BR185c_FirstGroup {
	loading: spriteset_BR185c_FirstGroup_loading;
	loaded: spriteset_BR185c_FirstGroup;
}
spritegroup spritegroup_BR185a_FirstGroup_rev {
	loading: spriteset_BR185a_FirstGroup_rev_loading;
	loaded: spriteset_BR185a_FirstGroup_rev;
}
spritegroup spritegroup_BR185b_FirstGroup_rev {
	loading: spriteset_BR185b_FirstGroup_rev_loading;
	loaded: spriteset_BR185b_FirstGroup_rev;
}
spritegroup spritegroup_BR185c_FirstGroup_rev {
	loading: spriteset_BR185c_FirstGroup_rev_loading;
	loaded: spriteset_BR185c_FirstGroup_rev;
}

spritegroup spritegroup_BR185a_FirstTPEGeometric {
	loading: spriteset_BR185a_FirstTPEGeometric_loading;
	loaded: spriteset_BR185a_FirstTPEGeometric;
}
spritegroup spritegroup_BR185b_FirstTPEGeometric {
	loading: spriteset_BR185b_FirstTPEGeometric_loading;
	loaded: spriteset_BR185b_FirstTPEGeometric;
}
spritegroup spritegroup_BR185c_FirstTPEGeometric {
	loading: spriteset_BR185c_FirstTPEGeometric_loading;
	loaded: spriteset_BR185c_FirstTPEGeometric;
}
spritegroup spritegroup_BR185a_FirstTPEGeometric_rev {
	loading: spriteset_BR185a_FirstTPEGeometric_rev_loading;
	loaded: spriteset_BR185a_FirstTPEGeometric_rev;
}
spritegroup spritegroup_BR185b_FirstTPEGeometric_rev {
	loading: spriteset_BR185b_FirstTPEGeometric_rev_loading;
	loaded: spriteset_BR185b_FirstTPEGeometric_rev;
}
spritegroup spritegroup_BR185c_FirstTPEGeometric_rev {
	loading: spriteset_BR185c_FirstTPEGeometric_rev_loading;
	loaded: spriteset_BR185c_FirstTPEGeometric_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR185a_FirstDynamic_loading_mode, param_loading_sprites) {
	0: spriteset_BR185a_FirstDynamic;
	spritegroup_BR185a_FirstDynamic;
}
switch(FEAT_TRAINS, SELF, sw_BR185b_FirstDynamic_loading_mode, param_loading_sprites) {
	0: spriteset_BR185b_FirstDynamic;
	spritegroup_BR185b_FirstDynamic;
}
switch(FEAT_TRAINS, SELF, sw_BR185c_FirstDynamic_loading_mode, param_loading_sprites) {
	0: spriteset_BR185c_FirstDynamic;
	spritegroup_BR185c_FirstDynamic;
}
switch(FEAT_TRAINS, SELF, sw_BR185a_FirstDynamic_rev_loading_mode, param_loading_sprites) {
	0: spriteset_BR185a_FirstDynamic_rev;
	spritegroup_BR185a_FirstDynamic_rev;
}
switch(FEAT_TRAINS, SELF, sw_BR185b_FirstDynamic_rev_loading_mode, param_loading_sprites) {
	0: spriteset_BR185b_FirstDynamic_rev;
	spritegroup_BR185b_FirstDynamic_rev;
}
switch(FEAT_TRAINS, SELF, sw_BR185c_FirstDynamic_rev_loading_mode, param_loading_sprites) {
	0: spriteset_BR185c_FirstDynamic_rev;
	spritegroup_BR185c_FirstDynamic_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR185a_FirstGroup_loading_mode, param_loading_sprites) {
	0: spriteset_BR185a_FirstGroup;
	spritegroup_BR185a_FirstGroup;
}
switch(FEAT_TRAINS, SELF, sw_BR185b_FirstGroup_loading_mode, param_loading_sprites) {
	0: spriteset_BR185b_FirstGroup;
	spritegroup_BR185b_FirstGroup;
}
switch(FEAT_TRAINS, SELF, sw_BR185c_FirstGroup_loading_mode, param_loading_sprites) {
	0: spriteset_BR185c_FirstGroup;
	spritegroup_BR185c_FirstGroup;
}
switch(FEAT_TRAINS, SELF, sw_BR185a_FirstGroup_rev_loading_mode, param_loading_sprites) {
	0: spriteset_BR185a_FirstGroup_rev;
	spritegroup_BR185a_FirstGroup_rev;
}
switch(FEAT_TRAINS, SELF, sw_BR185b_FirstGroup_rev_loading_mode, param_loading_sprites) {
	0: spriteset_BR185b_FirstGroup_rev;
	spritegroup_BR185b_FirstGroup_rev;
}
switch(FEAT_TRAINS, SELF, sw_BR185c_FirstGroup_rev_loading_mode, param_loading_sprites) {
	0: spriteset_BR185c_FirstGroup_rev;
	spritegroup_BR185c_FirstGroup_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR185a_FirstTPEGeometric_loading_mode, param_loading_sprites) {
	0: spriteset_BR185a_FirstTPEGeometric;
	spritegroup_BR185a_FirstTPEGeometric;
}
switch(FEAT_TRAINS, SELF, sw_BR185b_FirstTPEGeometric_loading_mode, param_loading_sprites) {
	0: spriteset_BR185b_FirstTPEGeometric;
	spritegroup_BR185b_FirstTPEGeometric;
}
switch(FEAT_TRAINS, SELF, sw_BR185c_FirstTPEGeometric_loading_mode, param_loading_sprites) {
	0: spriteset_BR185c_FirstTPEGeometric;
	spritegroup_BR185c_FirstTPEGeometric;
}
switch(FEAT_TRAINS, SELF, sw_BR185a_FirstTPEGeometric_rev_loading_mode, param_loading_sprites) {
	0: spriteset_BR185a_FirstTPEGeometric_rev;
	spritegroup_BR185a_FirstTPEGeometric_rev;
}
switch(FEAT_TRAINS, SELF, sw_BR185b_FirstTPEGeometric_rev_loading_mode, param_loading_sprites) {
	0: spriteset_BR185b_FirstTPEGeometric_rev;
	spritegroup_BR185b_FirstTPEGeometric_rev;
}
switch(FEAT_TRAINS, SELF, sw_BR185c_FirstTPEGeometric_rev_loading_mode, param_loading_sprites) {
	0: spriteset_BR185c_FirstTPEGeometric_rev;
	spritegroup_BR185c_FirstTPEGeometric_rev;
}

// Stage 1: Choose livery based on cargo subtype.
switch(FEAT_TRAINS, SELF, sw_BR185a, cargo_subtype) {
	0: sw_BR185a_FirstDynamic_loading_mode;
	1: sw_BR185a_FirstGroup_loading_mode;
	2: sw_BR185a_FirstTPEGeometric_loading_mode;
	default: sw_BR185a_FirstDynamic_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR185b, cargo_subtype) {
	0: sw_BR185b_FirstDynamic_loading_mode;
	1: sw_BR185b_FirstGroup_loading_mode;
	2: sw_BR185b_FirstTPEGeometric_loading_mode;
	default: sw_BR185b_FirstDynamic_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR185c, cargo_subtype) {
	0: sw_BR185c_FirstDynamic_loading_mode;
	1: sw_BR185c_FirstGroup_loading_mode;
	2: sw_BR185c_FirstTPEGeometric_loading_mode;
	default: sw_BR185c_FirstDynamic_loading_mode;
}

// Stage 2: when reversing, grab the mirrored cargo subtype so the sprite remains on the same livery.
switch(FEAT_TRAINS, SELF, sw_BR185a_rev, [STORE_TEMP(position_in_consist_from_end-position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: sw_BR185a_FirstDynamic_rev_loading_mode;
	1: sw_BR185a_FirstGroup_rev_loading_mode;
	2: sw_BR185a_FirstTPEGeometric_rev_loading_mode;
	default: sw_BR185a_FirstDynamic_rev_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR185b_rev, [STORE_TEMP(position_in_consist_from_end-position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: sw_BR185b_FirstDynamic_rev_loading_mode;
	1: sw_BR185b_FirstGroup_rev_loading_mode;
	2: sw_BR185b_FirstTPEGeometric_rev_loading_mode;
	default: sw_BR185b_FirstDynamic_rev_loading_mode;
}

switch(FEAT_TRAINS, SELF, sw_BR185c_rev, [STORE_TEMP(position_in_consist_from_end-position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: sw_BR185c_FirstDynamic_rev_loading_mode;
	1: sw_BR185c_FirstGroup_rev_loading_mode;
	2: sw_BR185c_FirstTPEGeometric_rev_loading_mode;
	default: sw_BR185c_FirstDynamic_rev_loading_mode;
}

// Provide text for the available liveries.
switch(FEAT_TRAINS,SELF,sw_BR185_cargo_subtype_text,cargo_subtype){
	0:	return string(str_FirstDynamic);
	1:	return string(str_FirstGroup);
	2:	return string(str_FirstTPEGeometric);
	return CB_RESULT_NO_TEXT;
}

// Stage 3: map articulated position to role in forward direction.
switch(FEAT_TRAINS, SELF, sw_BR185_roles_fwd, position_in_articulated_veh % 3) {
	0: sw_BR185a;
	1: sw_BR185b;
	2: sw_BR185c;
	sw_BR185a;
}

// Stage 4: when reversed, use mirrored articulated position to preserve role at each map tile.
switch(FEAT_TRAINS, SELF, sw_BR185_rev_role_3car, [STORE_TEMP(position_in_consist_from_end-position_in_consist, 0x10F), var[0x61, 0, 0x000000FF, 0x41] % 3]) {
	0: sw_BR185a_rev;
	1: sw_BR185b_rev;
	2: sw_BR185c_rev;
	sw_BR185a_rev;
}

// Final selector: use forward role chain unless the consist is reversed.
switch(FEAT_TRAINS, PARENT, sw_BR185_pushpull, vehicle_is_reversed) {
	1: sw_BR185_rev_role_3car;
	sw_BR185_roles_fwd;
}
