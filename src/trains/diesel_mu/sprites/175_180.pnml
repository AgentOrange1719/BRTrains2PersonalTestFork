// Unified Class 175 / 180 sprite and push-pull mappings.
// Shared approach:
// 1) choose local role sprites from articulated position and local cargo_subtype
// 2) choose reversed role sprites from mirrored articulated position and mirrored cargo_subtype
// 3) choose the reversed role chain from the mirrored unit type in mixed 175/180 formations

// --------------------
// Class 175 sprites
// --------------------
spriteset(spriteset_BR175_Purchase, "gfx/DMU/175.png") { template_purchase(0, 0) }

spriteset(spriteset_BR175_front_TfW, "gfx/DMU/175.png") { template_train32px(0, 13) }
spriteset(spriteset_BR175_rear_TfW, "gfx/DMU/175.png") { template_train32px(0, 39) }
spriteset(spriteset_BR175_middle_TfW, "gfx/DMU/175.png") { template_train32px(0, 65) }
spriteset(spriteset_BR175_front_TfW_rev, "gfx/DMU/175.png") { template_train32px_reversed(200, 13) }
spriteset(spriteset_BR175_rear_TfW_rev, "gfx/DMU/175.png") { template_train32px_reversed(200, 39) }
spriteset(spriteset_BR175_middle_TfW_rev, "gfx/DMU/175.png") { template_train32px_reversed(0, 65) }
spriteset(spriteset_BR175_front_ATW, "gfx/DMU/175.png") { template_train32px(0, 91) }
spriteset(spriteset_BR175_rear_ATW, "gfx/DMU/175.png") { template_train32px(0, 117) }
spriteset(spriteset_BR175_middle_ATW, "gfx/DMU/175.png") { template_train32px(0, 143) }
spriteset(spriteset_BR175_front_ATW_rev, "gfx/DMU/175.png") { template_train32px_reversed(200, 91) }
spriteset(spriteset_BR175_rear_ATW_rev, "gfx/DMU/175.png") { template_train32px_reversed(200, 117) }
spriteset(spriteset_BR175_middle_ATW_rev, "gfx/DMU/175.png") { template_train32px_reversed(0, 143) }
spriteset(spriteset_BR175_front_FNW, "gfx/DMU/175.png") { template_train32px(0, 169) }
spriteset(spriteset_BR175_rear_FNW, "gfx/DMU/175.png") { template_train32px(0, 195) }
spriteset(spriteset_BR175_middle_FNW, "gfx/DMU/175.png") { template_train32px(0, 221) }
spriteset(spriteset_BR175_front_FNW_rev, "gfx/DMU/175.png") { template_train32px_reversed(200, 169) }
spriteset(spriteset_BR175_rear_FNW_rev, "gfx/DMU/175.png") { template_train32px_reversed(200, 195) }
spriteset(spriteset_BR175_middle_FNW_rev, "gfx/DMU/175.png") { template_train32px_reversed(0, 221) }
spriteset(spriteset_BR175_front_ATWGhost, "gfx/DMU/175.png") { template_train32px(0, 247) }
spriteset(spriteset_BR175_rear_ATWGhost, "gfx/DMU/175.png") { template_train32px(0, 273) }
spriteset(spriteset_BR175_middle_ATWGhost, "gfx/DMU/175.png") { template_train32px(0, 299) }
spriteset(spriteset_BR175_front_ATWGhost_rev, "gfx/DMU/175.png") { template_train32px_reversed(200, 247) }
spriteset(spriteset_BR175_rear_ATWGhost_rev, "gfx/DMU/175.png") { template_train32px_reversed(200, 273) }
spriteset(spriteset_BR175_middle_ATWGhost_rev, "gfx/DMU/175.png") { template_train32px_reversed(0, 299) }

switch(FEAT_TRAINS, SELF, sw_BR175_front, cargo_subtype) {
	0: spriteset_BR175_front_ATWGhost;
	1: spriteset_BR175_front_FNW;
	2: spriteset_BR175_front_ATW;
	3: spriteset_BR175_front_TfW;
	default: spriteset_BR175_front_ATWGhost;
}

switch(FEAT_TRAINS, SELF, sw_BR175_middle, cargo_subtype) {
	0: spriteset_BR175_middle_ATWGhost;
	1: spriteset_BR175_middle_FNW;
	2: spriteset_BR175_middle_ATW;
	3: spriteset_BR175_middle_TfW;
	default: spriteset_BR175_middle_ATWGhost;
}

switch(FEAT_TRAINS, SELF, sw_BR175_rear, cargo_subtype) {
	0: spriteset_BR175_rear_ATWGhost;
	1: spriteset_BR175_rear_FNW;
	2: spriteset_BR175_rear_ATW;
	3: spriteset_BR175_rear_TfW;
	default: spriteset_BR175_rear_ATWGhost;
}

// Class 175 reversed sprites use dedicated reverse-cab artwork.
switch(FEAT_TRAINS, SELF, sw_BR175_front_rev_mirror_subtype, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR175_front_ATWGhost_rev;
	1: spriteset_BR175_front_FNW_rev;
	2: spriteset_BR175_front_ATW_rev;
	3: spriteset_BR175_front_TfW_rev;
	default: spriteset_BR175_front_ATWGhost_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR175_middle_rev_mirror_subtype, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR175_middle_ATWGhost_rev;
	1: spriteset_BR175_middle_FNW_rev;
	2: spriteset_BR175_middle_ATW_rev;
	3: spriteset_BR175_middle_TfW_rev;
	default: spriteset_BR175_middle_ATWGhost_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR175_rear_rev_mirror_subtype, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR175_rear_ATWGhost_rev;
	1: spriteset_BR175_rear_FNW_rev;
	2: spriteset_BR175_rear_ATW_rev;
	3: spriteset_BR175_rear_TfW_rev;
	default: spriteset_BR175_rear_ATWGhost_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR175_2car_roles_fwd, position_in_articulated_veh % 2) {
	0: sw_BR175_front;
	sw_BR175_rear;
}

switch(FEAT_TRAINS, SELF, sw_BR175_3car_roles_fwd, position_in_articulated_veh % 3) {
	0: sw_BR175_front;
	2: sw_BR175_rear;
	sw_BR175_middle;
}

switch(FEAT_TRAINS, SELF, sw_BR175_rev_role_2car, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x000000FF, 0x41] % 2]) {
	0: sw_BR175_front_rev_mirror_subtype;
	sw_BR175_rear_rev_mirror_subtype;
}

switch(FEAT_TRAINS, SELF, sw_BR175_rev_role_3car, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x000000FF, 0x41] % 3]) {
	0: sw_BR175_front_rev_mirror_subtype;
	2: sw_BR175_rear_rev_mirror_subtype;
	sw_BR175_middle_rev_mirror_subtype;
}

switch(FEAT_TRAINS, SELF, sw_BR175_cargo_subtype_text, cargo_subtype) {
	0: return string(str_ArrivaGhost);
	1: return string(str_FirstNorthWestern);
	2: return string(str_ArrivaWales);
	3: return string(str_TfW);
	return CB_RESULT_NO_TEXT;
}

