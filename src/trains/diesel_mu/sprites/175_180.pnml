switch(FEAT_TRAINS, SELF, sw_BR180a, cargo_subtype) {
	0: spriteset_BR180a_FGW;
	1: spriteset_BR180a_FGWDL;
	2: spriteset_BR180a_GC;
	3: spriteset_BR180a_GCLined;
	4: spriteset_BR180a_NorthernRail;
	5: spriteset_BR180a_EMRMaroonWhite;
	default: spriteset_BR180a_FGW;
}

switch(FEAT_TRAINS, SELF, sw_BR180b, cargo_subtype) {
	0: spriteset_BR180b_FGW;
	1: spriteset_BR180b_FGWDL;
	2: spriteset_BR180b_GC;
	3: spriteset_BR180b_GCLined;
	4: spriteset_BR180b_NorthernRail;
	5: spriteset_BR180b_EMRMaroonWhite;
	default: spriteset_BR180b_FGW;
}

switch(FEAT_TRAINS, SELF, sw_BR180c, cargo_subtype) {
	0: spriteset_BR180c_FGW;
	1: spriteset_BR180c_FGWDL;
	2: spriteset_BR180c_GC;
	3: spriteset_BR180c_GCLined;
	4: spriteset_BR180c_NorthernRail;
	5: spriteset_BR180c_EMRMaroonWhite;
	default: spriteset_BR180c_FGW;
}

// Class 180 reversed sprites use dedicated reverse-cab artwork.
switch(FEAT_TRAINS, SELF, sw_BR180a_rev_mirror_subtype, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR180a_FGW_rev;
	1: spriteset_BR180a_FGWDL_rev;
	2: spriteset_BR180a_GC_rev;
	3: spriteset_BR180a_GCLined_rev;
	4: spriteset_BR180a_NorthernRail_rev;
	5: spriteset_BR180a_EMRMaroonWhite_rev;
	default: spriteset_BR180a_FGW_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR180b_rev_mirror_subtype, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR180b_FGW_rev;
	1: spriteset_BR180b_FGWDL_rev;
	2: spriteset_BR180b_GC_rev;
	3: spriteset_BR180b_GCLined_rev;
	4: spriteset_BR180b_NorthernRail_rev;
	5: spriteset_BR180b_EMRMaroonWhite_rev;
	default: spriteset_BR180b_FGW_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR180c_rev_mirror_subtype, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xF2]]) {
	0: spriteset_BR180c_FGW_rev;
	1: spriteset_BR180c_FGWDL_rev;
	2: spriteset_BR180c_GC_rev;
	3: spriteset_BR180c_GCLined_rev;
	4: spriteset_BR180c_NorthernRail_rev;
	5: spriteset_BR180c_EMRMaroonWhite_rev;
	default: spriteset_BR180c_FGW_rev;
}

switch(FEAT_TRAINS, SELF, sw_BR180_roles_fwd, position_in_articulated_veh % 5) {
	0: sw_BR180a;
	4: sw_BR180c;
	sw_BR180b;
}

switch(FEAT_TRAINS, SELF, sw_BR180_rev_role_5car, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x000000FF, 0x41] % 5]) {
	0: sw_BR180a_rev_mirror_subtype;
	4: sw_BR180c_rev_mirror_subtype;
	sw_BR180b_rev_mirror_subtype;
}

switch(FEAT_TRAINS, SELF, sw_BR180_cargo_subtype_text, cargo_subtype) {
	0: return string(str_FGW);
	1: return string(str_FGWDL);
	2: return string(str_GC);
	3: return string(str_GCLined);
	4: return string(str_NorthernRail);
	5: return string(str_EMRMaroonWhite);
	return CB_RESULT_NO_TEXT;
}

// Shared reverse-role resolver for mixed 175/180 formations.
switch(FEAT_TRAINS, SELF, sw_BR175_180_rev_from_mirror, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xC6]]) {
	339: sw_BR175_rev_role_2car;
	2339: sw_BR175_rev_role_2car;
	340: sw_BR175_rev_role_3car;
	2340: sw_BR175_rev_role_3car;
	67: sw_BR180_rev_role_5car;
	2067: sw_BR180_rev_role_5car;
	68: sw_BR180_rev_role_5car;
	69: sw_BR180_rev_role_5car;
	230: sw_BR180_rev_role_5car;
	2068: sw_BR180_rev_role_5car;
	2069: sw_BR180_rev_role_5car;
	2230: sw_BR180_rev_role_5car;
	sw_BR175_rev_role_2car;
}

switch(FEAT_TRAINS, PARENT, sw_BR175_2car_pushpull, vehicle_is_reversed) {
	1: sw_BR175_180_rev_from_mirror;
	sw_BR175_2car_roles_fwd;
}

switch(FEAT_TRAINS, PARENT, sw_BR175_3car_pushpull, vehicle_is_reversed) {
	1: sw_BR175_180_rev_from_mirror;
	sw_BR175_3car_roles_fwd;
}

switch(FEAT_TRAINS, PARENT, sw_BR180_pushpull, vehicle_is_reversed) {
	1: sw_BR175_180_rev_from_mirror;
	sw_BR180_roles_fwd;
}
