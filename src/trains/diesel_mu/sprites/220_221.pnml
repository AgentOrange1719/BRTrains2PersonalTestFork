// Shared reverse-role resolver for mixed 220/221 formations.
switch(FEAT_TRAINS, SELF, sw_BR220_221_rev_from_mirror, [STORE_TEMP(position_in_consist_from_end - position_in_consist, 0x10F), var[0x61, 0, 0x0000FFFF, 0xC6]]) {
	185: sw_BR220_rev_role_4car;
	2185: sw_BR220_rev_role_4car;
	188: sw_BR221_rev_role_5car;
	2188: sw_BR221_rev_role_5car;
	192: sw_BR221_4_rev_role_4car;
	2192: sw_BR221_4_rev_role_4car;
	sw_BR220_rev_role_4car;
}

switch(FEAT_TRAINS, PARENT, sw_BR220_pushpull, vehicle_is_reversed) {
	1: sw_BR220_221_rev_from_mirror;
	sw_BR220_roles_fwd_4car;
}

switch(FEAT_TRAINS, PARENT, sw_BR221_pushpull, vehicle_is_reversed) {
	1: sw_BR220_221_rev_from_mirror;
	sw_BR221_roles_fwd_5car;
}

switch(FEAT_TRAINS, PARENT, sw_BR221_4_pushpull, vehicle_is_reversed) {
	1: sw_BR220_221_rev_from_mirror;
	sw_BR221_4_roles_fwd_4car;
}
