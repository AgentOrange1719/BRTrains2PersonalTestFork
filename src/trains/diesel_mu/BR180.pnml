// Class 180 (5-car)
// Formation: A-B-B-B-C

switch(FEAT_TRAINS, SELF, switch_articulated_BR180, extra_callback_info1) {
	1..4: return item_BR180;
	return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

switch(FEAT_TRAINS, SELF, sw_BR180_cargo_capacity, position_in_articulated_veh % 5) {
	0: return(55 * param_pax);
	4: return(55 * param_pax);
	return(59 * param_pax);
}

switch(FEAT_TRAINS, SELF, switch_BR180_can_attach_wagon, vehicle_type_id) {
	item_BR180: return CB_RESULT_ATTACH_ALLOW;
	item_BR175_2car: return CB_RESULT_ATTACH_ALLOW;
	item_BR175_3car: return CB_RESULT_ATTACH_ALLOW;
	return string(STR_CANNOT_ATTACH);
}
switch(FEAT_TRAINS, SELF, switch_BR180_sound_muted, getbits(extra_callback_info1, 0, 8)) {
	SOUND_EVENT_BREAKDOWN: SOUND_BREAKDOWN_TRAIN_SHIP;
}
item(FEAT_TRAINS, item_BR180, 67) {
	property {
		name: 							string(STR_NAME_BR180);
		climates_available: 			ALL_CLIMATES;
		introduction_date:				date(2002,4,21);
		model_life:						8;
		retire_early:					1;
		vehicle_life:					50;
		reliability_decay:				7;
		refittable_cargo_classes:		CC_PASSENGERS;
		cargo_allow_refit:				[PASS, TOUR];
		loading_speed:					14;
		cost_factor:					92;
		running_cost_factor:			68;
		sprite_id:						SPRITE_ID_NEW_TRAIN;
		speed:							125 mph;
		refit_cost:						0;
		track_type:						RAIL;
		ai_special_flag:				AI_FLAG_CARGO;
		power:							3750 hp;
		running_cost_base:				RUNNING_COST_DIESEL;
		dual_headed:					0;
		default_cargo_type:				PASS;
		cargo_capacity:					55;
		weight:							253 ton;
		engine_class:					ENGINE_CLASS_DIESEL;
		tractive_effort_coefficient:	0.3;
		air_drag_coefficient:			0.1;
		length:							8;
		effect_spawn_model_and_powered:	EFFECT_SPAWN_MODEL_DIESEL;
		extra_weight_per_wagon:			0;
		bitmask_vehicle_info:			0;
		cargo_age_period:				185;
	}
	graphics {
		additional_text:				return(string(str_purchase_loco_with_liveries_and_mw,string(str_purchase_type_dmu),string(str_BR180_usage),string(STR_CONCAT_2, string(str_multiple_working_within_class), string(str_multiple_working_with_class_175)),string(str_BR180_eos),string(str_BR180_liveries)));
		can_attach_wagon:				switch_BR180_can_attach_wagon;
		cargo_subtype_text:				sw_BR180_cargo_subtype_text;
		articulated_part:       		switch_articulated_BR180;
		default: 						sw_BR180_pushpull;
		purchase:						spriteset_BR180_Purchase;
		colour_mapping: 				return PALETTE_CC_FIRST;
		create_effect:					diesel_create_visual_effect;
		sound_effect:					sw_sound_diesel_220;
		power:							return 3750;
		tractive_effort_coefficient:	return 76;
		cargo_capacity:					sw_BR180_cargo_capacity;
		cost_factor:					return(GetAdjustedCost(92));
		running_cost_factor: 			return(GetAdjustedCost(68));
	}
}
